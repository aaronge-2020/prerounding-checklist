NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-or-anon-key

# Optional aliases used by Node import/export scripts.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-publishable-or-anon-key

# Server-only. Never paste this into Workup Studio or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-import-export-only
SUPABASE_ACCESS_TOKEN=your-supabase-cli-access-token
SUPABASE_DB_PASSWORD=your-hosted-postgres-password
SUPABASE_PROJECT_REF=your-project-ref

# Workup Studio auth. magic-link is the default and does not require OAuth secrets.
WORKUP_STUDIO_AUTH_METHOD=magic-link
WORKUP_STUDIO_REVIEWER_EMAIL=reviewer@example.com

# Optional OAuth fallback if WORKUP_STUDIO_AUTH_METHOD=oauth.
WORKUP_STUDIO_OAUTH_PROVIDER=google
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-oauth-client-secret
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=your-github-oauth-client-id
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=your-github-oauth-client-secret
