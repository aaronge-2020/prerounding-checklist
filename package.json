{
  "name": "prerounding-checklist",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:medical-knowledge",
    "build:qr-dictionary": "node scripts/build-qr-zstd-dictionary.js",
    "check:qr-dictionary": "node scripts/check-qr-dictionary.js",
    "build:evidence": "node scripts/build-physical-exam-evidence.js",
    "build:index-html-symbol-map": "node scripts/gen-index-html-symbol-map.js",
    "build:index-html-css-map": "node scripts/gen-index-html-css-region-map.js",
    "test": "npm run test:core && npm run test:clinical",
    "test:core": "npm run test:syntax && npm run test:deid && npm run test:labs && npm run test:checklist && npm run test:vault-entry && npm run test:vault-state && npm run test:continuity",
    "test:clinical": "npm run test:clinical-intents && npm run test:medical-knowledge && npm run test:workup-authoring && npm run test:workup-studio-auth && npm run test:workup-studio-ui && npm run test:supabase-config && npm run test:supabase-catalog-race && npm run test:supabase-catalog-refresh && npm run test:supabase-catalog-empty && npm run test:complaint-cds && npm run test:open-evidence && npm run test:endocrine-knowledge && npm run test:clinical-ui",
    "test:deid": "node tests/test-deid.js",
    "test:labs": "node tests/test-labs.js",
    "test:checklist": "node tests/test-checklist.js",
    "test:vault-entry": "node tests/test-vault-entry.js",
    "test:vault-state": "node tests/test-vault-state-machine.js",
    "test:continuity": "node tests/test-continuity.js",
    "test:clinical-intents": "node tests/test-clinical-intents.js",
    "build:medical-knowledge": "node scripts/build-medical-knowledge-db.js",
    "import:medical-knowledge": "node scripts/import-medical-knowledge.js",
    "export:medical-knowledge": "node scripts/export-medical-knowledge.js",
    "grant:workup-access": "node scripts/grant-workup-access.js",
    "deploy:supabase-workup-authoring": "node scripts/deploy-supabase-workup-authoring.js",
    "check:supabase-auth": "node scripts/check-supabase-auth-readiness.js",
    "check:supabase-public": "node scripts/check-supabase-auth-readiness.js --public-only",
    "test:medical-knowledge": "node tests/test-medical-knowledge-db.js",
    "test:workup-authoring": "node scripts/test-workup-authoring.js",
    "test:workup-studio-auth": "node tests/test-workup-studio-auth.js",
    "test:workup-studio-ui": "node tests/test-workup-studio-ui.js",
    "test:supabase-catalog-race": "node tests/test-supabase-catalog-race.js",
    "test:supabase-catalog-refresh": "node tests/test-supabase-catalog-refresh.js",
    "test:supabase-catalog-empty": "node tests/test-supabase-catalog-empty.js",
    "test:supabase-config": "node tests/test-supabase-config.js",
    "test:complaint-cds": "node tests/test-complaint-cds.js",
    "test:open-evidence": "node tests/test-open-evidence-workflows.js",
    "test:desktop-ui": "node tests/test-desktop-responsive-ui.js",
    "test:qr-optimizer": "node tests/test-qr-zstd-dictionary.js && node tests/test-qr-zstd-library-coverage.js",
    "test:qr-library": "node tests/test-qr-zstd-library-coverage.js",
    "generate:endocrine-workups": "node scripts/generate-endocrine-workups.js",
    "install:endocrine-workups": "node scripts/install-endocrine-workups.js",
    "refresh:endocrine-workups": "npm run generate:endocrine-workups && npm run install:endocrine-workups && npm run build:medical-knowledge && npm run test:endocrine-knowledge",
    "test:endocrine-knowledge": "node tests/test-endocrine-knowledge.js",
    "test:clinical-ui": "node tests/test-clinical-ui-browser.js",
    "benchmark:deid": "node tests/benchmark-deid.js",
    "build:mesh-vocabulary": "node scripts/build-mesh-vocabulary.js",
    "build:clinical-guard-vocabulary": "node scripts/build-clinical-guard-vocabulary.js",
    "apply:clinical-guard-vocabulary": "node scripts/apply-clinical-guard-vocabulary.js --install",
    "build:clinical-guard-full": "npm run build:mesh-vocabulary && npm run build:clinical-guard-vocabulary && npm run apply:clinical-guard-vocabulary",
    "benchmark:deid:large": "node tests/benchmark-deid.js --include-large",
    "test:syntax": "node scripts/check-syntax.js"
  },
  "dependencies": {
    "@bokuweb/zstd-wasm": "^0.0.27",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@zxing/browser": "^0.2.0",
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0"
  }
}
