{
  "name": "prerounding-checklist",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:core && npm run test:local-ui",
    "test:ci": "npm run lint && npm run test:core && npm run test:local-ui",
    "test:core": "npm run test:syntax && npm run test:state && npm run test:deid && npm run test:prompts && npm run test:workups && npm run test:workup-systems && npm run test:workup-libraries && npm run test:workup-mirror && npm run test:openai-workup && npm run test:deid-model-options && npm run test:model-packs",
    "test:state": "node tests/test-local-first-state.js",
    "test:prompts": "node tests/test-local-first-prompts.js",
    "test:workups": "node tests/test-local-first-workups.js",
    "test:workup-systems": "node tests/test-workup-systems.js",
    "test:workup-libraries": "node tests/test-admission-workups.js",
    "test:workup-mirror": "node tests/test-workup-workspace-mirror.js",
    "test:openai-workup": "node tests/test-openai-workup-format.js",
    "test:deid-model-options": "node tests/test-deid-model-options.js",
    "test:model-packs": "node tests/test-model-packs.js",
    "test:local-ui": "node tests/test-local-first-ui-browser.js",
    "test:deid": "node tests/test-deid.js",
    "test:syntax": "node scripts/check-syntax.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "playwright": "^1.61.0",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "fuse.js": "^7.0.0"
  }
}
