{
  "name": "prerounding-checklist",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:medical-knowledge",
    "build:evidence": "node scripts/build-physical-exam-evidence.js",
    "test": "npm run test:core && npm run test:clinical && npm run test:evidence-suite",
    "test:core": "npm run test:syntax && npm run test:deid && npm run test:labs && npm run test:checklist && npm run test:vault-entry && npm run test:vault-state && npm run test:continuity",
    "test:clinical": "npm run test:clinical-intents && npm run test:medical-knowledge && npm run test:workup-authoring && npm run test:workup-studio-auth && npm run test:workup-studio-ui && npm run test:supabase-config && npm run test:complaint-cds && npm run test:open-evidence && npm run test:endocrine-knowledge && npm run test:embedding && npm run test:clinical-pathways && npm run test:clinical-ui",
    "test:evidence-suite": "npm run test:evidence && npm run test:evidence:eval && npm run test:evidence:adversarial && npm run test:workup-quality && npm run test:intent-workup-audit",
    "test:deid": "node scripts/test-deid.js",
    "test:labs": "node scripts/test-labs.js",
    "test:checklist": "node scripts/test-checklist.js",
    "test:vault-entry": "node scripts/test-vault-entry.js",
    "test:vault-state": "node scripts/test-vault-state-machine.js",
    "test:continuity": "node scripts/test-continuity.js",
    "test:clinical-intents": "node scripts/test-clinical-intents.js",
    "build:medical-knowledge": "node scripts/build-medical-knowledge-db.js",
    "import:medical-knowledge": "node scripts/import-medical-knowledge.js",
    "export:medical-knowledge": "node scripts/export-medical-knowledge.js",
    "grant:workup-access": "node scripts/grant-workup-access.js",
    "deploy:supabase-workup-authoring": "node scripts/deploy-supabase-workup-authoring.js",
    "check:supabase-auth": "node scripts/check-supabase-auth-readiness.js",
    "check:supabase-public": "node scripts/check-supabase-auth-readiness.js --public-only",
    "test:medical-knowledge": "node scripts/test-medical-knowledge-db.js",
    "test:workup-authoring": "node scripts/test-workup-authoring.js",
    "test:workup-studio-auth": "node scripts/test-workup-studio-auth.js",
    "test:workup-studio-ui": "node scripts/test-workup-studio-ui.js",
    "test:supabase-config": "node scripts/test-supabase-config.js",
    "test:complaint-cds": "node scripts/test-complaint-cds.js",
    "test:open-evidence": "node scripts/test-open-evidence-workflows.js",
    "test:evidence": "node scripts/test-evidence.js",
    "test:evidence:eval": "node scripts/test-evidence-eval.js",
    "test:evidence:adversarial": "node scripts/test-evidence-adversarial.js",
    "test:workup-quality": "node scripts/test-clinical-workup-quality.js",
    "test:desktop-ui": "node scripts/test-desktop-responsive-ui.js",
    "test:intent-workup-audit": "node scripts/test-clinical-intent-workup-audit.js",
    "iterate:clinical-workups": "node scripts/iterate-clinical-workups.js --out=reports/clinical-workup-audit-current.md --json=reports/clinical-workup-audit-current.json --latest-out=reports/clinical-workup-audit-latest.md --latest-json=reports/clinical-workup-audit-latest.json",
    "generate:clinical-pathways": "node scripts/hand-polish-clinical-pathway-trees.js",
    "audit:clinical-pathways": "node scripts/audit-clinical-pathway-trees.js --strict --out=reports/clinical-pathway-tree-audit-2026-06-11.md --json=reports/clinical-pathway-tree-audit-2026-06-11.json --latest-out=reports/clinical-pathway-tree-audit-latest.md --latest-json=reports/clinical-pathway-tree-audit-latest.json",
    "test:clinical-pathways": "node scripts/hand-polish-clinical-pathway-trees.js --check && node scripts/audit-clinical-pathway-trees.js --strict && node scripts/audit-clinical-cutoff-gaps.js --json=reports/clinical-cutoff-gap-audit-latest.json --out=reports/clinical-cutoff-gap-audit-latest.md",
    "generate:endocrine-workups": "node scripts/generate-endocrine-workups.js",
    "install:endocrine-workups": "node scripts/install-endocrine-workups.js",
    "refresh:endocrine-workups": "npm run generate:endocrine-workups && npm run install:endocrine-workups && npm run build:medical-knowledge && npm run test:endocrine-knowledge",
    "test:endocrine-knowledge": "node scripts/test-endocrine-knowledge.js",
    "test:embedding": "node scripts/test-embedding-recall.js",
    "test:clinical-ui": "node scripts/test-clinical-ui-browser.js",
    "test:deid:adversarial": "node scripts/test-deid-adversarial.js",
    "generate:deid:adversarial": "node scripts/generate-deid-adversarial-cases.js",
    "benchmark:deid": "node scripts/benchmark-deid.js",
    "benchmark:deid:large": "node scripts/benchmark-deid.js --include-large",
    "benchmark:embedding": "node scripts/benchmark-embedding-models.js",
    "test:syntax": "node scripts/check-syntax.js"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
