          "implementation_notes": ""
        }
      },
      {
        "id": "dka_euglycemic_risk",
        "label": "SGLT2 inhibitor, pregnancy, fasting, or lower glucose with ketotic symptoms",
        "action": "Do not exclude DKA based only on glucose; check ketones and acidosis.",
        "when": {
          "termsAny": [
            "sglt2",
            "empagliflozin",
            "dapagliflozin",
            "canagliflozin",
            "pregnant",
            "fasting",
            "euglycemic"
