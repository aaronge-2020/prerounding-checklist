{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prerounding.local/schemas/workup-change-set-v1.schema.json",
  "title": "Workup Change Set v1",
  "description": "Section-scoped review patch format used by Workup Studio and public contribution review workflows.",
  "type": "object",
  "required": ["schema", "workupId", "sectionKey", "operations"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "workup_change_set_v1" },
    "id": { "type": "string" },
    "workupId": { "type": "string", "minLength": 1 },
    "workup_id": { "type": "string", "minLength": 1 },
    "sectionKey": {
      "enum": [
        "clinical_pathway_tree_v1",
        "history_questions",
        "physical_exam",
        "safety_checks",
        "initial_tests",
        "red_flags",
        "management_disposition",
        "sources",
        "review_tests"
      ]
    },
    "section_key": { "type": "string" },
    "summary": { "type": "string" },
    "operations": {
      "type": "array",
      "items": { "$ref": "#/$defs/operation" }
    },
    "sourceIds": { "$ref": "#/$defs/stringArray" },
    "source_ids": { "$ref": "#/$defs/stringArray" },
    "reviewStatus": { "enum": ["draft", "pending_review", "approved", "rejected", "exported"] },
    "review_status": { "enum": ["draft", "pending_review", "approved", "rejected", "exported"] },
    "exportReady": { "type": "boolean" },
    "export_ready": { "type": "boolean" },
    "authorId": { "type": ["string", "null"] },
    "author_id": { "type": ["string", "null"] },
    "reviewerNotes": { "type": "string" },
    "reviewer_notes": { "type": "string" },
    "createdAt": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "operation": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": true,
      "properties": {
        "op": { "enum": ["replace_section", "add", "update", "remove"] },
        "path": { "type": "string" },
        "groupKey": { "type": "string" },
        "itemId": { "type": "string" },
        "before": {},
        "after": {},
        "item": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "op": { "const": "add" } }, "required": ["op"] },
          "then": { "required": ["groupKey", "item"] }
        },
        {
          "if": {
            "properties": { "op": { "enum": ["update", "remove"] } },
            "required": ["op"]
          },
          "then": { "required": ["itemId"] }
        },
        {
          "if": { "properties": { "op": { "const": "replace_section" } }, "required": ["op"] },
          "then": { "required": ["before", "after"] }
        }
      ]
    }
  }
}
