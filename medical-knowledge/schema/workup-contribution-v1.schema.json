{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prerounding.local/schemas/workup-contribution-v1.schema.json",
  "title": "Public Workup Contribution v1",
  "description": "Student-friendly, pasteable draft format for public GitHub issue submissions. This is not reviewed clinical guidance.",
  "type": "object",
  "required": ["schema", "title", "sources"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "workup_contribution_v1" },
    "title": { "type": "string", "minLength": 3 },
    "workup_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_\\-]{2,120}$" },
    "aliases": { "$ref": "#/$defs/stringArray" },
    "triggers": { "$ref": "#/$defs/stringArray" },
    "population": { "type": "string", "minLength": 1 },
    "applicability": { "$ref": "#/$defs/applicability" },
    "history_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/historyQuestion" }
    },
    "physical_exam_maneuvers": {
      "type": "array",
      "items": { "$ref": "#/$defs/physicalExamManeuver" }
    },
    "diagnostic_tests": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnosticTest" }
    },
    "safety_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/commonItem" }
    },
    "red_flags": {
      "type": "array",
      "items": { "$ref": "#/$defs/commonItem" }
    },
    "management_disposition": {
      "type": "array",
      "items": { "$ref": "#/$defs/commonItem" }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "reviewer_notes": { "type": "string" },
    "review_status": {
      "enum": ["draft", "pending_review"],
      "default": "pending_review"
    }
  },
  "$defs": {
    "safePropertyName": {
      "not": {
        "pattern": "^(?:raw[\\s_-]*)?(?:(?:chart|patient|notes?|handoff|epic|mrn|dob|ssn|room|bed|address|phone|email|identifiers?)(?:[\\s_-]*(?:text|context|info|name|id|number|date|of[\\s_-]*birth|birthdate)s?)?|date[\\s_-]*of[\\s_-]*birth|birthdate)$"
      }
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sourceIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "applicability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "setting": { "type": "string", "minLength": 1 },
        "age_group": { "type": "string", "minLength": 1 },
        "use_when": { "$ref": "#/$defs/stringArray" },
        "do_not_use_when": { "$ref": "#/$defs/stringArray" }
      },
      "propertyNames": { "$ref": "#/$defs/safePropertyName" }
    },
    "commonItem": {
      "type": "object",
      "required": ["id", "item_type", "label"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_\\-]{1,120}$" },
        "item_type": {
          "enum": [
            "history_question",
            "physical_exam_maneuver",
            "diagnostic_test",
            "safety_check",
            "red_flag",
            "management_change",
            "diagnostic_frame",
            "reference_threshold"
          ]
        },
        "label": { "type": "string", "minLength": 1 },
        "tags": { "$ref": "#/$defs/stringArray" },
        "source_ids": { "$ref": "#/$defs/sourceIds" },
        "review_status": {
          "enum": ["draft", "pending_review", "reviewed", "rejected", "retired"],
          "default": "pending_review"
        },
        "review_notes": { "type": "string" },
        "diagnostic_target": { "type": "string" },
        "result_changes_management": { "type": "string" },
        "rationale": { "type": "string" },
        "action": { "type": "string" }
      },
      "propertyNames": { "$ref": "#/$defs/safePropertyName" }
    },
    "historyQuestion": {
      "allOf": [
        { "$ref": "#/$defs/commonItem" },
        {
          "type": "object",
          "required": ["question", "answer_options", "ask_when", "diagnostic_purpose", "result_changes_management"],
          "properties": {
            "item_type": { "const": "history_question" },
            "question": { "type": "string", "pattern": "\\?$" },
            "answer_options": {
              "type": "array",
              "minItems": 2,
              "items": { "type": "string", "minLength": 1 }
            },
            "ask_when": { "type": "string", "minLength": 1 },
            "diagnostic_purpose": { "type": "string", "minLength": 1 },
            "result_changes_management": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "physicalExamManeuver": {
      "allOf": [
        { "$ref": "#/$defs/commonItem" },
        {
          "type": "object",
          "required": ["include_when", "diagnostic_target", "result_changes_management", "custom_exam"],
          "properties": {
            "item_type": { "const": "physical_exam_maneuver" },
            "exam_id": { "type": "string", "minLength": 1 },
            "include_when": { "type": "string", "minLength": 1 },
            "diagnostic_target": { "type": "string", "minLength": 1 },
            "result_changes_management": { "type": "string", "minLength": 1 },
            "custom_exam": { "type": "boolean" }
          },
          "if": {
            "properties": { "custom_exam": { "const": false } },
            "required": ["custom_exam"]
          },
          "then": { "required": ["exam_id"] }
        }
      ]
    },
    "diagnosticTest": {
      "allOf": [
        { "$ref": "#/$defs/commonItem" },
        {
          "type": "object",
          "required": ["test_name", "order_when", "diagnostic_target", "interpretation", "result_changes_management"],
          "properties": {
            "item_type": { "const": "diagnostic_test" },
            "test_name": { "type": "string", "minLength": 1 },
            "order_when": { "type": "string", "minLength": 1 },
            "diagnostic_target": { "type": "string", "minLength": 1 },
            "interpretation": { "type": "string", "minLength": 1 },
            "result_changes_management": { "type": "string", "minLength": 1 },
            "threshold_ids": { "$ref": "#/$defs/sourceIds" }
          }
        }
      ]
    },
    "source": {
      "type": "object",
      "required": ["source_id", "citation", "url_or_doi", "source_type"],
      "additionalProperties": false,
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "citation": { "type": "string", "minLength": 1 },
        "url_or_doi": {
          "type": "string",
          "pattern": "^(?:https?://\\S+|doi:\\s*10\\.\\d{4,9}/\\S+|10\\.\\d{4,9}/\\S+)$"
        },
        "source_type": {
          "enum": ["guideline", "review", "primary_study", "textbook", "local_policy", "other"]
        },
        "date_accessed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "last_reviewed": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "next_review_due": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "review_owner": { "type": "string" },
        "currency_status": {
          "enum": ["reviewed_current_for_scope", "reviewed_legacy_active", "review_due", "retired"]
        }
      },
      "propertyNames": { "$ref": "#/$defs/safePropertyName" }
    }
  }
}
