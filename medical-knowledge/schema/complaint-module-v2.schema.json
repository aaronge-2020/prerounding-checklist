{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prerounding.local/schemas/complaint-module-v2.schema.json",
  "title": "Reviewed Complaint Module v2",
  "description": "Reviewed production workup schema. Existing complaint-cds-artifact-v1 modules remain supported through compatibility normalization.",
  "type": "object",
  "required": ["schema_version", "id", "label", "version", "status", "triggers", "source_ids"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "enum": ["complaint_module_v2", "complaint-cds-artifact-v1"] },
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "review_ready", "mvp", "active", "retired"] },
    "review_status": { "enum": ["draft", "pending_review", "reviewed", "rejected", "retired"] },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_at": { "type": "string" },
        "last_reviewed": { "type": "string" },
        "next_review_due": { "type": "string" },
        "review_owner": { "type": "string" },
        "retired_at": { "type": "string" },
        "retirement_reason": { "type": "string" }
      }
    },
    "triggers": { "$ref": "#/$defs/stringArray" },
    "aliases": { "$ref": "#/$defs/stringArray" },
    "source_ids": { "$ref": "#/$defs/stringArray" },
    "population": { "type": "object" },
    "applicability": { "type": "object" },
    "requiredQuestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/historyQuestion" }
    },
    "conditionalQuestions": {
      "type": "array",
      "items": { "$ref": "#/$defs/historyQuestion" }
    },
    "requiredExam": {
      "type": "array",
      "items": { "$ref": "#/$defs/physicalExam" }
    },
    "conditionalExam": {
      "type": "array",
      "items": { "$ref": "#/$defs/physicalExam" }
    },
    "source_registry_refs": {
      "description": "Source IDs must resolve against medical-knowledge/source-registry.json during build/test validation.",
      "$ref": "#/$defs/stringArray"
    },
    "compatibility_normalization": {
      "description": "Runtime/build compatibility accepts legacy field aliases and normalizes them to canonical names before review.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label_aliases": { "const": "label accepts text/action/technique/maneuver fallback only during legacy import" },
        "answer_options_alias": { "const": "answer_options accepts options fallback only during legacy import" },
        "ask_when_alias": { "const": "ask_when accepts when/trigger/when_to_ask fallback only during legacy import" },
        "include_when_alias": { "const": "include_when accepts when/trigger/when_to_perform fallback only during legacy import" },
        "likelihood_ratio_note_alias": { "const": "likelihood_ratio_note accepts LR_note/lr_note fallback only during legacy import" }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sourceReference": {
      "type": "object",
      "required": ["source_id", "source_section", "version_date", "last_reviewed", "clinical_owner"],
      "additionalProperties": true,
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_section": { "type": "string", "minLength": 1 },
        "evidence_strength": { "type": "string" },
        "version_date": { "type": "string", "minLength": 1 },
        "last_reviewed": { "type": "string", "minLength": 1 },
        "clinical_owner": { "type": "string", "minLength": 1 },
        "implementation_notes": { "type": "string" }
      }
    },
    "commonItem": {
      "type": "object",
      "required": ["id", "item_type", "label", "source"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "item_type": {
          "enum": [
            "history_question",
            "physical_exam_maneuver"
          ]
        },
        "label": { "type": "string", "minLength": 1 },
        "tags": { "$ref": "#/$defs/stringArray" },
        "source_ids": { "$ref": "#/$defs/stringArray" },
        "source": { "$ref": "#/$defs/sourceReference" },
        "review_status": {
          "enum": ["draft", "pending_review", "reviewed", "rejected", "retired"]
        },
        "review_notes": { "type": "string" },
        "diagnostic_target": { "type": "string" },
        "result_changes_management": { "type": "string" },
        "management_change": { "type": "string" },
        "likelihood_ratio_note": { "type": "string" },
        "LR_plus": { "type": "string" },
        "LR_minus": { "type": "string" }
      }
    },
    "historyQuestion": {
      "allOf": [
        { "$ref": "#/$defs/commonItem" },
        {
          "type": "object",
          "required": ["text", "answer_options", "ask_when", "diagnostic_purpose", "result_changes_management"],
          "properties": {
            "item_type": { "const": "history_question" },
            "text": { "type": "string", "pattern": "\\?$" },
            "answer_options": { "$ref": "#/$defs/stringArray" },
            "ask_when": { "type": "string", "minLength": 1 },
            "diagnostic_purpose": { "type": "string", "minLength": 1 },
            "result_changes_management": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "physicalExam": {
      "allOf": [
        { "$ref": "#/$defs/commonItem" },
        {
          "type": "object",
          "required": ["include_when", "diagnostic_target", "result_changes_management"],
          "properties": {
            "item_type": { "const": "physical_exam_maneuver" },
            "exam_id": { "type": "string", "minLength": 1 },
            "custom_exam": { "type": "boolean", "default": false },
            "include_when": { "type": "string", "minLength": 1 },
            "technique": { "type": "string" },
            "findings_options": { "$ref": "#/$defs/stringArray" },
            "diagnostic_target": { "type": "string", "minLength": 1 },
            "result_changes_management": { "type": "string", "minLength": 1 },
            "difficulty": { "enum": ["easy", "moderate", "hard", "difficult"] },
            "time_burden_minutes": {
              "anyOf": [
                { "type": "number", "minimum": 0 },
                { "type": "string", "pattern": "^\\d+(?:\\.\\d+)?$" }
              ]
            },
            "equipment_needed": { "type": "string" },
            "patient_cooperation_required": { "enum": ["low", "moderate", "high", "n/a"] },
            "limitations": { "type": "string" }
          },
          "if": {
            "properties": { "custom_exam": { "const": false } }
          },
          "then": { "required": ["exam_id"] }
        }
      ]
    }
  }
}
