{
  "schema": "prerounding_workup_v1",
  "id": "acute-kidney-injury",
  "title": "Acute kidney injury",
  "aliases": [
    "AKI",
    "acute renal failure"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you been eating and drinking normally, or have you had vomiting or diarrhea?",
      "choices": [
        "Normal oral intake",
        "Poor oral intake",
        "Vomiting or diarrhea"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you noticed a change in how much you're urinating?",
      "choices": [
        "Normal urine output",
        "Decreased urine output",
        "No urine output"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you have heart failure or cirrhosis?",
      "choices": [
        "Neither",
        "Known heart failure",
        "Known cirrhosis"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "medication",
      "text": "Have you taken any ibuprofen, naproxen, or other NSAID pain relievers recently?",
      "choices": [
        "No recent NSAID use",
        "Recent NSAID use"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Do you take a blood pressure medication ending in -pril or -sartan, or a water pill?",
      "choices": [
        "None of these",
        "ACE inhibitor or ARB use",
        "Diuretic use"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Have you had a CT scan or other imaging test with contrast dye recently?",
      "choices": [
        "No recent contrast administration",
        "Recent intravenous contrast administration"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "medication",
      "text": "Have you started a new antibiotic recently, along with a rash or fever?",
      "choices": [
        "No new antibiotic with rash or fever",
        "New antibiotic with rash or fever"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you had trouble starting your stream or noticed it's weaker than usual, or do you have an enlarged prostate, stones, or a bladder condition?",
      "choices": [
        "No voiding difficulty",
        "Difficulty voiding or weak stream",
        "Known benign prostatic hyperplasia, stones, or neurogenic bladder"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "genitourinary",
      "text": "Do you have a urinary catheter, and has it been draining normally?",
      "choices": [
        "No catheter",
        "Catheter present, functioning normally",
        "Catheter present, concern for blockage"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had significant muscle pain, or has your urine looked dark like tea or cola?",
      "choices": [
        "Neither",
        "Muscle pain",
        "Dark, tea-colored urine"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Were you stuck in one position for a long time, down on the floor for a while after a fall, or crushed under something heavy?",
      "choices": [
        "None of these",
        "Prolonged immobilization or extended down time after a fall",
        "Crush injury"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you seen blood in your urine, or noticed new swelling or high blood pressure?",
      "choices": [
        "None of these",
        "Hematuria",
        "New edema and hypertension"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "genitourinary",
      "text": "Do you have chronic kidney disease, and has your kidney function been stable or worsening lately?",
      "choices": [
        "No known chronic kidney disease",
        "Known chronic kidney disease, stable baseline",
        "Known chronic kidney disease with a recent creatinine increase"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you had an episode of very low blood pressure recently, or lost a significant amount of blood?",
      "choices": [
        "Neither",
        "Recent hypotensive episode",
        "Recent significant blood loss"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "general",
      "text": "Assess overall volume status.",
      "choices": [
        "Euvolemic",
        "Hypovolemic, with dry mucous membranes or poor turgor",
        "Hypervolemic, with edema or elevated jugular venous pressure"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess jugular venous pressure.",
      "choices": [
        "Normal jugular venous pressure",
        "Elevated jugular venous pressure"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Inspect and palpate the lower extremities for edema.",
      "choices": [
        "No peripheral edema",
        "Peripheral edema present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess for bladder distention.",
      "choices": [
        "Nondistended",
        "Distended, palpable bladder"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess for costovertebral-angle tenderness.",
      "choices": [
        "None",
        "Unilateral costovertebral-angle tenderness",
        "Bilateral costovertebral-angle tenderness"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for a new rash.",
      "choices": [
        "No new rash",
        "New rash present"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Palpate muscle groups for focal tenderness or swelling suggesting rhabdomyolysis.",
      "choices": [
        "No focal muscle tenderness or swelling",
        "Focal muscle tenderness or swelling"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess orthostatic vital signs when safe.",
      "choices": [
        "Negative orthostatics",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for ascites or jaundice suggesting hepatorenal physiology.",
      "choices": [
        "Neither",
        "Ascites",
        "Jaundice"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess urine output, by catheter if placed.",
      "choices": [
        "Adequate urine output",
        "Minimal or absent output despite a functioning catheter"
      ],
      "select": "one"
    }
  ]
}
