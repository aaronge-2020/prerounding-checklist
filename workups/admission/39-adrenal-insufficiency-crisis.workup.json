{
  "schema": "prerounding_workup_v1",
  "id": "adrenal-insufficiency-crisis",
  "title": "Adrenal insufficiency / adrenal crisis",
  "aliases": [
    "adrenal crisis",
    "adrenal insufficiency"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been feeling profoundly weak or tired, out of proportion to how sick you feel otherwise?",
      "choices": [
        "No profound fatigue",
        "Profound, out-of-proportion fatigue"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had nausea, vomiting, or belly pain along with the weakness?",
      "choices": [
        "None of these",
        "Nausea or vomiting",
        "Abdominal pain"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt dizzy or lightheaded, especially when standing up?",
      "choices": [
        "No dizziness",
        "Dizzy or lightheaded on standing"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been craving salty foods, or lost weight without trying?",
      "choices": [
        "Neither",
        "Salt craving",
        "Unintentional weight loss"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Are you on a steroid medication like prednisone, and have you missed doses or run out recently?",
      "choices": [
        "Not on chronic steroids",
        "On chronic steroids, taking as prescribed",
        "On chronic steroids, missed doses or ran out"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Have you been sick recently, had surgery, or gone through some other stress that would normally require extra steroid dosing?",
      "choices": [
        "No recent physiologic stress",
        "Recent illness, surgery, or major stress without stress-dose steroids"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "infectious",
      "text": "Do you have a fever or symptoms of an infection right now?",
      "choices": [
        "No fever or infection symptoms",
        "Fever or infection symptoms present"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "skin",
      "text": "Have you or others noticed your skin getting darker, especially in creases or scars?",
      "choices": [
        "No skin darkening",
        "New hyperpigmentation"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have a known adrenal, pituitary, or autoimmune condition, or have you had an adrenal crisis before?",
      "choices": [
        "None of these",
        "Known adrenal or pituitary disease",
        "Prior adrenal crisis"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had vomiting or diarrhea that kept you from taking your usual medications?",
      "choices": [
        "No vomiting or diarrhea affecting medications",
        "Vomiting or diarrhea preventing medication intake"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt confused, or has anyone said you seem less alert than usual?",
      "choices": [
        "No confusion",
        "New confusion or decreased alertness"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had muscle or joint pain along with the weakness?",
      "choices": [
        "No muscle or joint pain",
        "Diffuse muscle or joint pain"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Measure blood pressure lying and standing to assess for orthostatic hypotension.",
      "choices": [
        "No orthostatic change",
        "Positive orthostatic hypotension",
        "Hypotensive supine"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess heart rate and overall hemodynamic stability.",
      "choices": [
        "Normal heart rate, hemodynamically stable",
        "Tachycardic",
        "In shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "general",
      "text": "Assess temperature for fever.",
      "choices": [
        "Afebrile",
        "Febrile"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect skin, creases, and scars for hyperpigmentation.",
      "choices": [
        "No hyperpigmentation",
        "Hyperpigmentation present"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "skin",
      "text": "Assess mucous membranes and skin turgor for dehydration.",
      "choices": [
        "Moist mucous membranes, normal turgor",
        "Dry mucous membranes or poor turgor"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status and orientation.",
      "choices": [
        "Alert and oriented",
        "Confused or lethargic",
        "Obtunded"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness.",
      "choices": [
        "Soft, nontender",
        "Diffuse tenderness",
        "Guarding or rigidity"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for vitiligo or other autoimmune skin findings.",
      "choices": [
        "None present",
        "Vitiligo present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "endocrine",
      "text": "Check fingerstick glucose.",
      "choices": [
        "Normal glucose",
        "Hypoglycemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess proximal muscle strength.",
      "choices": [
        "Normal strength",
        "Proximal muscle weakness"
      ],
      "select": "one"
    }
  ]
}
