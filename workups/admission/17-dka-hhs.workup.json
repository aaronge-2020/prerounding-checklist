{
  "schema": "prerounding_workup_v1",
  "id": "dka-hhs",
  "title": "Diabetes mellitus with complications (DKA, HHS)",
  "aliases": [
    "diabetic ketoacidosis",
    "hyperosmolar hyperglycemic state"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been urinating much more than usual?",
      "choices": [
        "No polyuria",
        "Polyuria"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been unusually thirsty?",
      "choices": [
        "No polydipsia",
        "Polydipsia"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been diagnosed with diabetes before, and if so, do you take insulin or pills for it?",
      "choices": [
        "Known type 1 diabetes on insulin",
        "Known type 2 diabetes",
        "No prior diabetes diagnosis, possible new onset"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "medication",
      "text": "Have you been taking your insulin as prescribed, or has your insulin pump had any problems?",
      "choices": [
        "Adherent, no pump issues",
        "Missed insulin doses",
        "Insulin pump malfunction or interruption"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have belly pain?",
      "choices": [
        "No abdominal pain",
        "Abdominal pain"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had nausea or vomiting?",
      "choices": [
        "Neither",
        "Nausea",
        "Vomiting"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever or felt sick before this started?",
      "choices": [
        "No fever or infectious symptoms",
        "Fever or infectious symptoms"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "medication",
      "text": "Are you taking a diabetes medication that ends in -gliflozin, like empagliflozin or canagliflozin?",
      "choices": [
        "Not on an SGLT2 inhibitor",
        "Currently on an SGLT2 inhibitor"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "neurologic",
      "text": "Compared to normal, is the patient acting the same, a little more confused, or very sleepy and hard to wake up?",
      "choices": [
        "Alert and at baseline per family or caregiver",
        "Mild new confusion",
        "Significant lethargy or unresponsiveness"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "medication",
      "text": "Have you been drinking a lot of alcohol recently?",
      "choices": [
        "No recent heavy alcohol use",
        "Recent heavy alcohol use"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you had any chest pain?",
      "choices": [
        "No chest pain",
        "Chest pain"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you lost weight without trying over the past few weeks?",
      "choices": [
        "No unintentional weight loss",
        "Unintentional weight loss over recent weeks"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "functional",
      "text": "Have you had trouble affording or getting access to your insulin?",
      "choices": [
        "No barrier identified",
        "Cost or access barrier",
        "Intentional nonadherence"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you had an episode like this before, where your blood sugar was dangerously high?",
      "choices": [
        "First episode",
        "Recurrent episodes"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Lethargic",
        "Obtunded or comatose"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess respiratory pattern for Kussmaul breathing.",
      "choices": [
        "Normal breathing pattern",
        "Rapid, deep Kussmaul breathing"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "ent",
      "text": "Assess breath odor for a fruity or acetone smell.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "general",
      "text": "Assess hydration status.",
      "choices": [
        "Euvolemic",
        "Dry mucous membranes or poor skin turgor",
        "Severe dehydration with hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness.",
      "choices": [
        "Nontender",
        "Diffuse tenderness without peritoneal signs"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "endocrine",
      "text": "Check fingerstick glucose.",
      "choices": [
        "Under 250 mg/dL",
        "250 to 600 mg/dL",
        "Over 600 mg/dL, suggesting hyperosmolar state"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess vital signs for tachycardia or hypotension.",
      "choices": [
        "Normal vital signs",
        "Tachycardic",
        "Hypotensive"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Assess skin turgor.",
      "choices": [
        "Normal skin turgor",
        "Poor turgor or tenting"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "infectious",
      "text": "Examine for a focal infectious source.",
      "choices": [
        "No focal source identified",
        "Focal source identified"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit or seizure activity, which can occur with hyperosmolar state.",
      "choices": [
        "No focal deficit or seizure",
        "Focal neurologic deficit or seizure activity"
      ],
      "select": "one"
    }
  ]
}
