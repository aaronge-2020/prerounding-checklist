{
  "schema": "prerounding_workup_v1",
  "id": "dizziness-vertigo",
  "title": "Dizziness / vertigo",
  "aliases": [
    "vertigo",
    "lightheadedness"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "neurologic",
      "text": "Does it feel like the room is spinning, like you're about to faint, or just unsteady without spinning?",
      "choices": [
        "Spinning, room-spinning vertigo",
        "Lightheaded, near-fainting sensation",
        "Unsteadiness or imbalance without spinning"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "neurologic",
      "text": "Do the episodes last just a few seconds, several hours, or has it been constant for days?",
      "choices": [
        "Brief episodes lasting seconds",
        "Continuous vertigo lasting days",
        "Episodic vertigo lasting hours"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Does the dizziness happen when you roll over in bed or look up?",
      "choices": [
        "Not positional",
        "Triggered by rolling over in bed or looking up"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "ent",
      "text": "Have you noticed any hearing loss or ringing in your ears?",
      "choices": [
        "Neither",
        "Hearing loss",
        "Tinnitus"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had double vision, facial numbness, weakness, or clumsiness in your arms or legs along with the dizziness?",
      "choices": [
        "None of these",
        "Double vision or facial numbness",
        "Limb weakness or incoordination"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "neurologic",
      "text": "Do you have a headache along with the dizziness?",
      "choices": [
        "No headache",
        "Headache accompanying the dizziness"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "infectious",
      "text": "Did you have a cold or upper respiratory infection before this started?",
      "choices": [
        "No preceding upper respiratory infection",
        "Preceding upper respiratory infection"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you have coronary artery disease, an irregular heartbeat, or a family history of sudden cardiac death?",
      "choices": [
        "None of these",
        "Known coronary artery disease or arrhythmia",
        "Family history of sudden cardiac death"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Have you started a new blood pressure medication or an antibiotic that can affect hearing or balance?",
      "choices": [
        "Neither",
        "New antihypertensive",
        "New ototoxic medication"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes, and did you feel shaky, sweaty, or hungry along with the dizziness?",
      "choices": [
        "No known diabetes",
        "Known diabetes without hypoglycemic symptoms",
        "Known diabetes with hypoglycemic symptoms"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "psychiatric",
      "text": "Did this happen during a stressful moment when you were breathing fast?",
      "choices": [
        "No situational anxiety trigger",
        "Situational anxiety trigger with hyperventilation"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been told you're anemic or have low blood counts?",
      "choices": [
        "No known anemia",
        "Known anemia"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had episodes like this before?",
      "choices": [
        "First episode",
        "Recurrent similar episodes"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for nystagmus.",
      "choices": [
        "No nystagmus",
        "Unidirectional horizontal nystagmus",
        "Direction-changing or vertical nystagmus"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for skew deviation.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess tandem gait when safe.",
      "choices": [
        "Normal tandem gait",
        "Unable to walk tandem, ataxic gait"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess orthostatic vital signs when safe.",
      "choices": [
        "Negative orthostatics",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess cardiac rhythm.",
      "choices": [
        "Regular rhythm",
        "Irregular rhythm"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "neurologic",
      "text": "Perform the Dix-Hallpike maneuver when clinically appropriate.",
      "choices": [
        "Negative or not indicated",
        "Positive, reproduces vertigo with nystagmus"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "ent",
      "text": "Assess hearing.",
      "choices": [
        "Normal hearing bilaterally",
        "Unilateral hearing loss"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit.",
      "choices": [
        "No focal deficit",
        "Focal deficit present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "hematologic",
      "text": "Inspect conjunctiva and nail beds for pallor.",
      "choices": [
        "Normal color",
        "Conjunctival or nail-bed pallor"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess coordination with finger-to-nose testing.",
      "choices": [
        "Normal coordination",
        "Dysmetria"
      ],
      "select": "one"
    }
  ]
}
