{
  "schema": "prerounding_workup_v1",
  "id": "venous-thromboembolism",
  "title": "Venous thromboembolism (DVT/PE)",
  "aliases": [
    "deep vein thrombosis",
    "pulmonary embolism"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Is one of your legs more swollen than the other?",
      "choices": [
        "No leg swelling",
        "Unilateral leg swelling"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you have pain or tenderness in your calf?",
      "choices": [
        "No calf pain or tenderness",
        "Calf pain or tenderness"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "respiratory",
      "text": "Do you have any sharp chest pain that's worse when you breathe in?",
      "choices": [
        "No pleuritic chest pain",
        "Pleuritic chest pain"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "respiratory",
      "text": "Did your shortness of breath come on gradually, or suddenly?",
      "choices": [
        "No dyspnea",
        "Gradual dyspnea",
        "Sudden-onset dyspnea"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "respiratory",
      "text": "Have you coughed up any blood?",
      "choices": [
        "No hemoptysis",
        "Hemoptysis"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt like you were going to pass out, or did you actually pass out?",
      "choices": [
        "Neither",
        "Presyncope",
        "Syncope"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "functional",
      "text": "Have you had surgery or been hospitalized recently?",
      "choices": [
        "Neither",
        "Recent surgery",
        "Recent hospitalization"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "functional",
      "text": "Have you been immobile for a long stretch, or traveled on a trip longer than four hours recently?",
      "choices": [
        "Neither",
        "Prolonged immobilization",
        "Long-distance travel over four hours"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "hematologic",
      "text": "Do you have an active cancer diagnosis?",
      "choices": [
        "No active malignancy",
        "Active malignancy"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you had a blood clot in your leg or lung before?",
      "choices": [
        "No known prior VTE",
        "Known prior deep vein thrombosis or pulmonary embolism"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "reproductive",
      "text": "Are you on hormone therapy or birth control pills, or currently pregnant or recently gave birth?",
      "choices": [
        "None of these",
        "Hormone therapy or oral contraceptive use",
        "Pregnant or postpartum"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with a clotting disorder, or does anyone in your family have a history of blood clots?",
      "choices": [
        "Neither",
        "Known thrombophilia",
        "Family history of venous thromboembolism"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "medication",
      "text": "Do you currently have, or did you recently have, a central line or PICC line?",
      "choices": [
        "No central venous catheter",
        "Current or recent central venous catheter"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had a recent leg injury, or are you in a cast or brace?",
      "choices": [
        "Neither",
        "Recent leg trauma",
        "Recent cast or immobilization device"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Compare leg circumference for asymmetric swelling.",
      "choices": [
        "Symmetric legs",
        "Unilateral swelling"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Palpate the calf for tenderness or a cord.",
      "choices": [
        "None",
        "Tenderness",
        "Palpable cord"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "skin",
      "text": "Assess the leg for warmth and erythema to help distinguish DVT from cellulitis.",
      "choices": [
        "Neither",
        "Warmth and erythema present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess heart rate.",
      "choices": [
        "Normal rate",
        "Tachycardic"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess oxygen saturation.",
      "choices": [
        "Normal saturation",
        "Hypoxemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "general",
      "text": "Assess hemodynamic stability.",
      "choices": [
        "Normotensive",
        "Hypotensive or in shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess jugular venous pressure and heart sounds for right heart strain.",
      "choices": [
        "Normal jugular venous pressure and heart sounds",
        "Elevated jugular venous pressure or a loud pulmonic component of S2"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "respiratory",
      "text": "Auscultate the lungs for focal findings.",
      "choices": [
        "Clear bilaterally",
        "Focal findings, such as a pleural rub or decreased breath sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "skin",
      "text": "Assess for cyanosis.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status and perfusion.",
      "choices": [
        "Alert with good perfusion",
        "Altered mental status or poor perfusion"
      ],
      "select": "one"
    }
  ]
}
