{
  "schema": "prerounding_workup_v1",
  "id": "copd-exacerbation",
  "title": "COPD exacerbation",
  "aliases": [
    "COPD flare",
    "emphysema exacerbation"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "respiratory",
      "text": "Compared to how you normally breathe, is your shortness of breath a little worse or severe even at rest?",
      "choices": [
        "No change from baseline",
        "Mild increase from baseline",
        "Severe increase, dyspnea at rest"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "respiratory",
      "text": "Are you coughing up more phlegm than usual?",
      "choices": [
        "No change in sputum volume",
        "Increased sputum volume"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "respiratory",
      "text": "Has the color of what you're coughing up changed, like turning yellow or green?",
      "choices": [
        "No change in sputum color",
        "New purulent or discolored sputum"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "respiratory",
      "text": "Is your wheezing worse than it usually is?",
      "choices": [
        "No change in wheeze",
        "Increased wheeze"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "respiratory",
      "text": "Did you have a sudden sharp chest pain that's worse when you breathe in?",
      "choices": [
        "No sudden pleuritic chest pain",
        "Sudden pleuritic chest pain"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "respiratory",
      "text": "Do you use oxygen at home, and if so, have you needed to turn it up higher than usual?",
      "choices": [
        "No home oxygen use",
        "Uses home oxygen at the usual baseline rate",
        "Recently increased home oxygen requirement"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "respiratory",
      "text": "Have you ever been admitted to the ICU or put on a breathing machine for a COPD flare before?",
      "choices": [
        "No prior hospitalization for COPD",
        "Prior hospitalization without ICU admission",
        "Prior ICU admission or intubation for COPD"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Have you been using your daily inhalers as prescribed?",
      "choices": [
        "Adherent to maintenance inhalers",
        "Missed inhaler doses",
        "Unable to afford or access inhalers"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "medication",
      "text": "Are you still smoking, or were you recently exposed to smoke, fumes, or other lung irritants?",
      "choices": [
        "No smoking or irritant exposure",
        "Ongoing active smoking",
        "New occupational or environmental irritant exposure"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had morning headaches or felt unusually sleepy during the day?",
      "choices": [
        "Neither",
        "Morning headache",
        "Daytime somnolence or new confusion"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you noticed leg swelling, or do you need extra pillows to breathe comfortably at night?",
      "choices": [
        "Neither",
        "Leg swelling",
        "Orthopnea"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "functional",
      "text": "Have you been immobilized, had recent surgery, or do you have cancer or a history of blood clots?",
      "choices": [
        "No provoking risk factor",
        "Recent immobilization or surgery",
        "Active malignancy or prior venous thromboembolism"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess work of breathing and ability to speak in full sentences.",
      "choices": [
        "Normal work of breathing, speaks in full sentences",
        "Accessory muscle use",
        "Tripod posture, unable to speak in full sentences"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "respiratory",
      "text": "Auscultate for wheeze and air movement.",
      "choices": [
        "Normal air entry, no wheeze",
        "Wheeze with adequate air movement",
        "Minimal air movement, silent chest"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess for pursed-lip breathing.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "respiratory",
      "text": "Percuss the chest for hyperresonance and assess diaphragmatic excursion.",
      "choices": [
        "Normal resonance and excursion",
        "Hyperresonant with reduced diaphragmatic excursion"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess breath sounds for asymmetry suggesting pneumothorax.",
      "choices": [
        "Symmetric breath sounds",
        "Unilateral decreased or absent breath sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess oxygenation.",
      "choices": [
        "Normal saturation on room air",
        "Hypoxemic, requiring supplemental oxygen",
        "Central cyanosis"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status and asterixis for hypercapnic respiratory failure.",
      "choices": [
        "Alert, no asterixis",
        "Somnolent or confused",
        "Asterixis present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess jugular venous pressure and peripheral edema for right-sided congestion.",
      "choices": [
        "Normal jugular venous pressure, no edema",
        "Elevated jugular venous pressure",
        "Elevated jugular venous pressure with peripheral edema"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess cardiac rhythm regularity.",
      "choices": [
        "Regular rhythm",
        "Irregular rhythm"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Inspect and palpate the calves for asymmetric swelling or tenderness.",
      "choices": [
        "Symmetric, no swelling or tenderness",
        "Unilateral swelling or tenderness"
      ],
      "select": "one"
    }
  ]
}
