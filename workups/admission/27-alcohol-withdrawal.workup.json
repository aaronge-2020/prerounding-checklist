{
  "schema": "prerounding_workup_v1",
  "id": "alcohol-withdrawal",
  "title": "Alcohol withdrawal",
  "aliases": [
    "delirium tremens",
    "DTs"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "medication",
      "text": "When was your last drink?",
      "choices": [
        "More than 7 days since last drink",
        "48 hours to 7 days since last drink",
        "Within the past 48 hours"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "How much do you typically drink in a day, and how long have you been drinking that much?",
      "choices": [
        "Light to moderate use",
        "Heavy daily use",
        "History of severe, long-standing dependence"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you ever had a seizure from stopping alcohol before?",
      "choices": [
        "No prior withdrawal seizure",
        "Prior withdrawal seizure"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you ever had delirium tremens, or severe confusion and shaking, from stopping alcohol before?",
      "choices": [
        "No prior delirium tremens",
        "Prior episode of delirium tremens"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "neurologic",
      "text": "Are you shaking, anxious, or feeling agitated right now?",
      "choices": [
        "None of these",
        "Mild tremor or anxiety",
        "Marked agitation"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "psychiatric",
      "text": "Have you been seeing or hearing things that aren't there?",
      "choices": [
        "No hallucinations",
        "Auditory or visual hallucinations with intact orientation",
        "Hallucinations with disorientation"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had nausea or vomiting?",
      "choices": [
        "Neither",
        "Nausea",
        "Vomiting"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been eating regular meals recently?",
      "choices": [
        "Adequate nutrition",
        "Poor nutrition or malnourishment"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Are you taking any benzodiazepines or opioids?",
      "choices": [
        "Neither",
        "Concurrent benzodiazepine use",
        "Concurrent opioid use"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have cirrhosis or another liver disease?",
      "choices": [
        "No known liver disease",
        "Known cirrhosis or liver disease"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "medication",
      "text": "Have you been trying to cut down on your own, on alcohol or a benzodiazepine, before coming in?",
      "choices": [
        "No recent self-tapering",
        "Recent self-tapering or dose reduction"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "psychiatric",
      "text": "Have you had any thoughts of harming yourself?",
      "choices": [
        "No suicidal ideation",
        "Suicidal ideation present"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you been eating and drinking normally in the days before you came in?",
      "choices": [
        "Normal oral intake",
        "Poor oral intake preceding admission"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for tremor.",
      "choices": [
        "Absent",
        "Mild tremor",
        "Coarse or marked tremor"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "skin",
      "text": "Assess for diaphoresis.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess vital sign stability.",
      "choices": [
        "Normal vital signs",
        "Tachycardic or hypertensive",
        "Severe autonomic instability"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess orientation.",
      "choices": [
        "Oriented to person, place, and time",
        "Disoriented"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "psychiatric",
      "text": "Assess agitation level.",
      "choices": [
        "Calm and cooperative",
        "Agitated",
        "Combative"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for hallucinations.",
      "choices": [
        "None observed",
        "Hallucinations observed"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for nystagmus, ataxia, or ophthalmoplegia suggesting Wernicke encephalopathy.",
      "choices": [
        "None of these",
        "Nystagmus or ataxia",
        "Ophthalmoplegia"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for stigmata of chronic liver disease.",
      "choices": [
        "No stigmata of liver disease",
        "Spider angiomata or jaundice"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for active or recent seizure activity.",
      "choices": [
        "None observed",
        "Active or recent seizure activity"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for bruising or needle marks.",
      "choices": [
        "None",
        "Bruising or needle marks present"
      ],
      "select": "one"
    }
  ]
}
