{
  "schema": "prerounding_workup_v1",
  "id": "bowel-obstruction",
  "title": "Bowel obstruction",
  "aliases": [
    "small bowel obstruction",
    "SBO",
    "large bowel obstruction"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Is your belly pain crampy and coming in waves, or is it constant?",
      "choices": [
        "Crampy, intermittent, colicky pain",
        "Constant, unrelenting pain"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Are you able to pass gas or have a bowel movement?",
      "choices": [
        "Passing flatus and stool normally",
        "Passing flatus but no stool",
        "Unable to pass gas or stool"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you been vomiting, and if so, does it look greenish-yellow or like stool?",
      "choices": [
        "No vomiting",
        "Bilious vomiting",
        "Feculent-appearing vomiting"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Has your belly become visibly more swollen or distended?",
      "choices": [
        "No distention",
        "Distention present"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had abdominal surgery in the past?",
      "choices": [
        "No prior abdominal surgery",
        "Prior abdominal surgery"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you noticed a bulge in your groin or at a prior surgical scar that you can push back in, or that's stuck out and painful?",
      "choices": [
        "No bulge noticed",
        "Reducible bulge",
        "Painful, irreducible bulge"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with cancer, especially of the colon, ovary, or stomach?",
      "choices": [
        "No known malignancy",
        "Known malignancy"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have Crohn's disease or another condition that has caused bowel narrowing before?",
      "choices": [
        "No known inflammatory bowel disease or stricture",
        "Known Crohn's disease or prior bowel stricture"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "infectious",
      "text": "Do you have a fever, or has the pain become constant and severe in one specific spot?",
      "choices": [
        "Neither",
        "Fever",
        "Constant severe localized pain"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you noticed blood in your stool, or had unintentional weight loss recently?",
      "choices": [
        "Neither",
        "Blood in stool",
        "Unintentional weight loss"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "medication",
      "text": "Are you on opioid pain medication, or have you been unusually constipated before this started?",
      "choices": [
        "Neither",
        "Regular opioid use",
        "Chronic constipation at baseline"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you noticed a change in how much you're urinating?",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Inspect the abdomen for distention and visible peristalsis.",
      "choices": [
        "No distention",
        "Distention present",
        "Distention with visible peristaltic waves"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Auscultate bowel sounds.",
      "choices": [
        "Normal bowel sounds",
        "High-pitched, hyperactive bowel sounds",
        "Absent bowel sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness, guarding, and rebound.",
      "choices": [
        "Soft, nontender",
        "Diffusely tender without guarding",
        "Focal tenderness, guarding, or rigidity"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Examine the inguinal, femoral, and umbilical hernia sites for a bulge and its reducibility.",
      "choices": [
        "No hernia identified",
        "Reducible hernia",
        "Tender, irreducible or incarcerated hernia"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the abdomen for surgical scars.",
      "choices": [
        "No surgical scars",
        "Prior surgical scars present"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "general",
      "text": "Assess temperature for fever.",
      "choices": [
        "Afebrile",
        "Febrile"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess hemodynamic stability.",
      "choices": [
        "Normotensive, stable",
        "Tachycardic",
        "Hypotensive or in shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination to assess for stool, mass, or blood.",
      "choices": [
        "Normal, stool present, guaiac negative",
        "Empty rectal vault",
        "Mass or gross blood on examination"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "general",
      "text": "Assess hydration status and mucous membranes.",
      "choices": [
        "Euvolemic, moist mucous membranes",
        "Dry mucous membranes or poor turgor"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess urine output.",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    }
  ]
}
