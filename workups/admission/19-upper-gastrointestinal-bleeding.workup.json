{
  "schema": "prerounding_workup_v1",
  "id": "upper-gastrointestinal-bleeding",
  "title": "Gastrointestinal bleeding (upper)",
  "aliases": [
    "upper GI bleed",
    "hematemesis"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you vomited anything that looked like blood or coffee grounds?",
      "choices": [
        "No hematemesis",
        "Coffee-ground emesis",
        "Bright red blood hematemesis"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "hematologic",
      "text": "Have your stools been black and tarry?",
      "choices": [
        "No melena",
        "Melena"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "medication",
      "text": "Do you regularly take ibuprofen or another NSAID, or aspirin?",
      "choices": [
        "Neither",
        "NSAID use",
        "Aspirin or antiplatelet use"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "medication",
      "text": "Are you on a blood thinner?",
      "choices": [
        "No anticoagulant use",
        "Anticoagulant use"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have cirrhosis or known varices in your esophagus?",
      "choices": [
        "Neither",
        "Known cirrhosis",
        "Known esophageal varices"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Do you drink alcohol heavily?",
      "choices": [
        "No heavy alcohol use",
        "Heavy alcohol use"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Did you have forceful retching or vomiting right before you noticed the blood?",
      "choices": [
        "No preceding retching or vomiting",
        "Forceful retching or vomiting preceded the bleeding"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you been diagnosed with a stomach ulcer or an H. pylori infection?",
      "choices": [
        "Neither",
        "Known peptic ulcer disease",
        "Known Helicobacter pylori infection"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with a cancer of the stomach or esophagus?",
      "choices": [
        "No known malignancy",
        "Known upper gastrointestinal malignancy"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you had surgery on your aorta, like a graft or aneurysm repair?",
      "choices": [
        "No known aortic graft or repair",
        "Known prior aortic graft or aneurysm repair"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have trouble swallowing?",
      "choices": [
        "No dysphagia",
        "Dysphagia"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you lost weight without trying?",
      "choices": [
        "No unintentional weight loss",
        "Unintentional weight loss"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt like you were going to pass out, or did you actually pass out with this bleeding?",
      "choices": [
        "Neither",
        "Presyncope",
        "Syncope"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have pain in your upper belly along with the bleeding?",
      "choices": [
        "No epigastric pain",
        "Epigastric pain"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess hemodynamic stability.",
      "choices": [
        "Normotensive, stable",
        "Tachycardic",
        "Hypotensive or in shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess orthostatic vital signs when safe.",
      "choices": [
        "Negative orthostatics",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "hematologic",
      "text": "Inspect conjunctiva and nail beds for pallor.",
      "choices": [
        "Normal color",
        "Conjunctival or nail-bed pallor"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness.",
      "choices": [
        "Nontender",
        "Epigastric tenderness",
        "Diffuse tenderness with peritoneal signs"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for stigmata of chronic liver disease.",
      "choices": [
        "No stigmata of liver disease",
        "Spider angiomata or palmar erythema",
        "Jaundice"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess the abdomen for ascites or splenomegaly.",
      "choices": [
        "Neither",
        "Ascites",
        "Splenomegaly"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination.",
      "choices": [
        "Normal, guaiac negative, or deferred as not indicated",
        "Melena on examination",
        "Bright red blood on examination"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Confused or altered"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess nasogastric aspirate, if placed.",
      "choices": [
        "Not performed or clear aspirate",
        "Coffee-ground aspirate",
        "Bright red blood aspirate"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect skin and mucosa for bleeding suggesting coagulopathy.",
      "choices": [
        "No ecchymosis or petechiae",
        "Ecchymosis or petechiae present"
      ],
      "select": "one"
    }
  ]
}
