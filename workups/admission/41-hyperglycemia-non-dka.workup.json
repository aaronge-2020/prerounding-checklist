{
  "schema": "prerounding_workup_v1",
  "id": "hyperglycemia-non-dka",
  "title": "Hyperglycemia (non-DKA)",
  "aliases": [
    "hyperglycemia",
    "high blood glucose"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes, and if so, is it type 1 or type 2?",
      "choices": [
        "No known diabetes",
        "Known type 2 diabetes",
        "Known type 1 diabetes"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "Have you missed doses of your insulin or diabetes medication recently?",
      "choices": [
        "Taking medication as prescribed",
        "Missed one or more doses",
        "Not on any diabetes medication"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you been urinating much more than usual or feeling unusually thirsty?",
      "choices": [
        "Neither",
        "Increased urination",
        "Increased thirst"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt confused, unusually sleepy, or had trouble staying awake?",
      "choices": [
        "No confusion or altered alertness",
        "Confusion or altered alertness"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had nausea, vomiting, or belly pain?",
      "choices": [
        "None of these",
        "Nausea or vomiting",
        "Abdominal pain"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "respiratory",
      "text": "Have you noticed your breathing becoming fast or deep, or a fruity smell to your breath?",
      "choices": [
        "Neither",
        "Fast or deep breathing",
        "Fruity breath odor"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you been drinking enough fluids, or has your urine output dropped off?",
      "choices": [
        "Drinking normally, normal urine output",
        "Poor oral intake",
        "Decreased urine output"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "infectious",
      "text": "Do you have a fever, cough, or burning with urination that might explain your sugar running high?",
      "choices": [
        "None of these",
        "Fever or cough",
        "Burning with urination"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Have you started a steroid medication recently?",
      "choices": [
        "No new steroid use",
        "Recently started steroids"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "medication",
      "text": "Have you been eating more sugary or carbohydrate-heavy food than usual, or drinking sugary drinks?",
      "choices": [
        "No significant dietary change",
        "Increased sugar or carbohydrate intake"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you had chest pain, or weakness on one side of your body, that could have triggered your sugar to rise?",
      "choices": [
        "Neither",
        "Chest pain",
        "New focal weakness"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "eyes",
      "text": "Has your vision been blurry?",
      "choices": [
        "No visual change",
        "Blurred vision"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status and orientation.",
      "choices": [
        "Alert and fully oriented",
        "Confused or lethargic",
        "Obtunded or comatose"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "general",
      "text": "Assess hydration status and skin turgor.",
      "choices": [
        "Euvolemic, normal turgor",
        "Dry mucous membranes or poor turgor"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Measure blood pressure lying and standing to assess for orthostatic hypotension.",
      "choices": [
        "No orthostatic change",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess respiratory pattern for Kussmaul breathing and check for a fruity breath odor.",
      "choices": [
        "Normal breathing pattern, no fruity odor",
        "Kussmaul breathing or fruity odor present"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness.",
      "choices": [
        "Soft, nontender",
        "Diffuse tenderness",
        "Focal tenderness or guarding"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "general",
      "text": "Assess temperature for fever.",
      "choices": [
        "Afebrile",
        "Febrile"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the feet and skin for ulcers, cellulitis, or other infection sources.",
      "choices": [
        "No skin or wound infection identified",
        "Skin or wound infection identified"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit.",
      "choices": [
        "No focal deficit",
        "Focal deficit present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "respiratory",
      "text": "Auscultate the lungs for a focal infiltrate.",
      "choices": [
        "Clear bilaterally",
        "Focal crackles or decreased breath sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess heart rate and rhythm.",
      "choices": [
        "Regular rate and rhythm",
        "Tachycardic",
        "Irregular rhythm"
      ],
      "select": "one"
    }
  ]
}
