{
  "schema": "prerounding_workup_v1",
  "id": "clostridioides-difficile-colitis",
  "title": "Clostridium difficile colitis",
  "aliases": [
    "C. diff",
    "pseudomembranous colitis"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "medication",
      "text": "Have you taken any antibiotics in the past eight weeks?",
      "choices": [
        "No recent antibiotic use",
        "Recent antibiotic course within 8 weeks"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "How many loose stools have you been having per day?",
      "choices": [
        "Fewer than 3 loose stools per day",
        "3 to 9 loose stools per day",
        "10 or more loose stools per day"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have belly pain or cramping?",
      "choices": [
        "None",
        "Mild cramping",
        "Severe abdominal pain"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever with shaking chills?",
      "choices": [
        "No fever",
        "Subjective fever",
        "Documented fever with rigors"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you noticed blood in your stool?",
      "choices": [
        "No blood in stool",
        "Blood in stool"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "infectious",
      "text": "Have you been hospitalized or stayed in a nursing home or long-term care facility recently?",
      "choices": [
        "Neither",
        "Recent hospitalization",
        "Long-term care facility stay"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had C. diff before?",
      "choices": [
        "First episode",
        "Recurrent episode"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have inflammatory bowel disease, like Crohn's or ulcerative colitis?",
      "choices": [
        "No known inflammatory bowel disease",
        "Known inflammatory bowel disease"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Are you on chemotherapy, a transplant medication, or long-term steroids?",
      "choices": [
        "No chronic immunosuppression",
        "Chronic immunosuppression"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "medication",
      "text": "Do you regularly take an acid reducer like omeprazole or another proton pump inhibitor?",
      "choices": [
        "No chronic PPI use",
        "Chronic PPI use"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Has your belly become more swollen or distended while your bowel movements have actually slowed down or stopped?",
      "choices": [
        "No distention or decreased output",
        "Distention with decreased stool output despite ongoing diarrhea"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you or your family noticed any confusion or unusual sleepiness?",
      "choices": [
        "Neither",
        "Confusion",
        "Lethargy"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness.",
      "choices": [
        "Nontender",
        "Diffuse tenderness",
        "Tenderness with guarding or rigidity"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for abdominal distention.",
      "choices": [
        "No distention",
        "Distention present"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Auscultate bowel sounds.",
      "choices": [
        "Normal bowel sounds",
        "Hyperactive bowel sounds",
        "Hypoactive or absent bowel sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "general",
      "text": "Assess hemodynamic stability.",
      "choices": [
        "Normotensive",
        "Tachycardic",
        "Hypotensive or in shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "general",
      "text": "Assess for fever.",
      "choices": [
        "Afebrile",
        "Febrile"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "skin",
      "text": "Assess hydration status.",
      "choices": [
        "Normal hydration",
        "Dry mucous membranes or poor skin turgor"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Confused or lethargic"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination when indicated.",
      "choices": [
        "Normal or deferred as not indicated",
        "Gross blood on examination"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for peritoneal signs suggesting perforation.",
      "choices": [
        "Absent",
        "Rebound or rigidity present"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess urine output.",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    }
  ]
}
