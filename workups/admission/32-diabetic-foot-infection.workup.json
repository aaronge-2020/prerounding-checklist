{
  "schema": "prerounding_workup_v1",
  "id": "diabetic-foot-infection",
  "title": "Diabetic foot infection",
  "aliases": [
    "diabetic foot ulcer",
    "foot infection"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "skin",
      "text": "How long have you had this wound?",
      "choices": [
        "New wound, under one week",
        "Chronic wound present for weeks",
        "Chronic non-healing wound present for months"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "skin",
      "text": "Is anything draining from the wound?",
      "choices": [
        "No drainage",
        "Serous drainage",
        "Purulent drainage"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Can you feel pain at the wound site, or do you have numbness there from neuropathy?",
      "choices": [
        "Pain present at the site",
        "No pain due to known neuropathy",
        "No pain reported despite a deep wound"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you been diagnosed with nerve damage or neuropathy in your feet?",
      "choices": [
        "No known peripheral neuropathy",
        "Known peripheral neuropathy"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you been diagnosed with poor circulation in your legs, or had an amputation before?",
      "choices": [
        "Neither",
        "Known peripheral arterial disease",
        "Prior amputation"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "endocrine",
      "text": "How has your blood sugar control been recently?",
      "choices": [
        "Good glycemic control per patient report",
        "Poor glycemic control"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "endocrine",
      "text": "How long have you had diabetes?",
      "choices": [
        "Under 10 years",
        "10 years or more"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you get calf pain when you walk that goes away when you rest?",
      "choices": [
        "No claudication symptoms",
        "Calf pain with walking, relieved by rest"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "skin",
      "text": "Has the redness been spreading quickly, and have you been feeling sick overall?",
      "choices": [
        "Gradual, localized to the wound",
        "Rapid spread with systemic illness"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Can you see bone in the wound, or has a doctor ever told you they could feel bone through it?",
      "choices": [
        "Neither",
        "Visible bone or prior probe-to-bone finding"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had a foot ulcer or amputation before?",
      "choices": [
        "Neither",
        "Prior foot ulcer",
        "Prior amputation"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "functional",
      "text": "Could this have started from an ill-fitting shoe or an injury you didn't notice?",
      "choices": [
        "No identifiable trauma",
        "Ill-fitting footwear or unnoticed trauma"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "skin",
      "text": "Assess wound depth.",
      "choices": [
        "Superficial",
        "Extends to subcutaneous tissue",
        "Extends to bone or joint"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "skin",
      "text": "Measure the extent of surrounding erythema.",
      "choices": [
        "Under 2 cm of surrounding erythema",
        "2 cm or more of surrounding erythema"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for purulent drainage.",
      "choices": [
        "None",
        "Purulent drainage present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Palpate pedal pulses.",
      "choices": [
        "Palpable pedal pulses",
        "Diminished pulses",
        "Absent pulses"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess protective sensation with a monofilament.",
      "choices": [
        "Intact protective sensation",
        "Loss of protective sensation"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Perform a probe-to-bone test.",
      "choices": [
        "Negative",
        "Positive, bone palpable through the wound"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "general",
      "text": "Assess for systemic signs of infection.",
      "choices": [
        "Afebrile and hemodynamically stable",
        "Febrile or tachycardic",
        "Hypotensive or septic-appearing"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for crepitus or necrotic tissue.",
      "choices": [
        "None",
        "Crepitus or necrotic tissue present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Inspect the foot for deformity or Charcot changes.",
      "choices": [
        "Normal foot architecture",
        "Deformity or Charcot changes present"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for lymphangitic streaking.",
      "choices": [
        "None",
        "Lymphangitic streaking present"
      ],
      "select": "one"
    }
  ]
}
