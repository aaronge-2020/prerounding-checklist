{
  "schema": "prerounding_workup_v1",
  "id": "anemia",
  "title": "Anemia (symptomatic or unexplained)",
  "aliases": [
    "low hemoglobin",
    "low hematocrit"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you noticed black, tarry stools, red blood in your stool, or vomited blood?",
      "choices": [
        "No signs of gastrointestinal bleeding",
        "Melena or hematochezia",
        "Hematemesis"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "reproductive",
      "text": "Have your periods been unusually heavy?",
      "choices": [
        "Not applicable or normal menses",
        "Heavy menstrual bleeding"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "hematologic",
      "text": "How is your diet — do you eat enough iron-rich or B12-rich foods, or are you vegan or vegetarian without supplements?",
      "choices": [
        "Adequate dietary intake",
        "Poor dietary iron or B12 intake",
        "Vegan or vegetarian diet without supplementation"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "general",
      "text": "How severe has your fatigue been — mild, or bad enough to limit your daily activities?",
      "choices": [
        "No unusual fatigue",
        "Mild fatigue",
        "Severe fatigue limiting activity"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "skin",
      "text": "Have your skin or eyes turned yellow, or has your urine looked dark?",
      "choices": [
        "Neither",
        "Jaundice",
        "Dark urine"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "genitourinary",
      "text": "Do you have chronic kidney disease?",
      "choices": [
        "No known chronic kidney disease",
        "Known chronic kidney disease"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with cancer?",
      "choices": [
        "No known malignancy",
        "Known malignancy"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you noticed easy bruising, or bleeding from your gums or nose?",
      "choices": [
        "Neither",
        "Easy bruising",
        "Bleeding gums or epistaxis"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "hematologic",
      "text": "Does anyone in your family have sickle cell disease or thalassemia?",
      "choices": [
        "No known family history",
        "Known family history of sickle cell disease or thalassemia"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "medication",
      "text": "Do you drink alcohol heavily?",
      "choices": [
        "No heavy alcohol use",
        "Heavy alcohol use"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "medication",
      "text": "Do you regularly take ibuprofen or another NSAID, or aspirin?",
      "choices": [
        "Neither",
        "NSAID use",
        "Aspirin or antiplatelet use"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had numbness or tingling, or trouble with your balance while walking?",
      "choices": [
        "Neither",
        "Paresthesias",
        "Gait imbalance"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had surgery or an injury recently?",
      "choices": [
        "Neither",
        "Recent surgery",
        "Recent trauma"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you been short of breath with activity, or had chest pain or palpitations?",
      "choices": [
        "Neither",
        "Dyspnea on exertion",
        "Chest pain or palpitations"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "hematologic",
      "text": "Inspect conjunctiva and palmar creases for pallor.",
      "choices": [
        "Normal color",
        "Conjunctival or palmar crease pallor"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect skin and sclerae for jaundice.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Auscultate the heart for tachycardia or a flow murmur.",
      "choices": [
        "Normal rate, no murmur",
        "Tachycardic",
        "Flow murmur present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess orthostatic vital signs when safe.",
      "choices": [
        "Negative orthostatics",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "ent",
      "text": "Inspect the tongue and lips for glossitis or angular cheilitis.",
      "choices": [
        "Normal oral exam",
        "Glossitis or angular cheilitis"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for splenomegaly.",
      "choices": [
        "No splenomegaly",
        "Splenomegaly present"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "hematologic",
      "text": "Palpate for lymphadenopathy.",
      "choices": [
        "No lymphadenopathy",
        "Lymphadenopathy present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination when indicated.",
      "choices": [
        "Normal, guaiac negative, or deferred as not indicated",
        "Melena or gross blood on examination"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect skin for petechiae or ecchymosis.",
      "choices": [
        "None",
        "Petechiae or ecchymosis present"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess vibration sense, proprioception, and gait for B12-related neuropathy.",
      "choices": [
        "Normal sensation and gait",
        "Decreased vibration or proprioception, or ataxic gait"
      ],
      "select": "one"
    }
  ]
}
