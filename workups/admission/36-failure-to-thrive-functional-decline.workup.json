{
  "schema": "prerounding_workup_v1",
  "id": "failure-to-thrive-functional-decline",
  "title": "Failure to thrive / functional decline (elderly)",
  "aliases": [
    "failure to thrive",
    "functional decline"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "functional",
      "text": "Compared to a few months ago, are you able to bathe, dress, and use the bathroom on your own, or do you need help now?",
      "choices": [
        "Independent with activities of daily living",
        "Newly needs assistance with activities of daily living",
        "Bedbound or fully dependent"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "functional",
      "text": "Have you lost weight without trying over the past few months?",
      "choices": [
        "No unintentional weight loss",
        "Unintentional weight loss"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "functional",
      "text": "Has your appetite changed recently?",
      "choices": [
        "No change in appetite",
        "Decreased appetite"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have any trouble chewing or swallowing your food?",
      "choices": [
        "No difficulty chewing or swallowing",
        "Difficulty chewing or swallowing"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "psychiatric",
      "text": "Have you been feeling down or lost interest in things you usually enjoy?",
      "choices": [
        "No low mood or anhedonia",
        "Low mood or anhedonia"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "neurologic",
      "text": "Have family or caregivers noticed your memory or thinking getting worse recently?",
      "choices": [
        "No noticed cognitive decline",
        "Family-noticed cognitive decline"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "functional",
      "text": "Who do you have helping you at home, and are you able to get the food, medications, and supplies you need?",
      "choices": [
        "Adequate supports, needs met",
        "Living alone with limited supports",
        "Unable to access food, medications, or supplies"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "functional",
      "text": "Have you fallen recently?",
      "choices": [
        "No recent fall",
        "Recent fall"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Have you started any new medications recently, especially anything for sleep, pain, or anxiety?",
      "choices": [
        "No new medication",
        "New sedating medication started"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever or any new pain?",
      "choices": [
        "Neither",
        "Fever",
        "New pain"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "psychiatric",
      "text": "Have you had any thoughts of harming yourself?",
      "choices": [
        "No suicidal ideation",
        "Suicidal ideation present"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "functional",
      "text": "Do you feel safe at home, and has anyone been physically rough with you or taken your money or belongings without permission?",
      "choices": [
        "Feels safe, no concerns",
        "Concern for abuse, neglect, or financial exploitation"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you had any accidents with your bladder or bowels recently that are new for you?",
      "choices": [
        "No new incontinence",
        "New urinary or bowel incontinence"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "general",
      "text": "Assess vital signs and hydration status.",
      "choices": [
        "Normal vital signs, euvolemic",
        "Abnormal vital signs or signs of dehydration"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess attention and level of consciousness.",
      "choices": [
        "Alert and fully oriented",
        "Inattentive or fluctuating alertness",
        "Lethargic or obtunded"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "general",
      "text": "Assess body habitus and nutritional status.",
      "choices": [
        "Normal body habitus",
        "Cachectic appearance"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "ent",
      "text": "Inspect the oral cavity and dentition.",
      "choices": [
        "Good dentition, moist mucous membranes",
        "Poor dentition or oral lesions",
        "Dry mucous membranes"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect skin and hygiene for evidence of neglect or pressure injury.",
      "choices": [
        "Skin intact, hygiene appropriate",
        "Poor hygiene",
        "Pressure ulcers or bruising in varying stages of healing"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess gait, balance, and safety of ambulation when safe.",
      "choices": [
        "Normal gait and balance",
        "Unsteady gait",
        "Unable to ambulate safely"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess proximal muscle strength.",
      "choices": [
        "Normal strength",
        "Proximal muscle weakness"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Auscultate the heart for rate, rhythm, and murmurs.",
      "choices": [
        "Normal rate and regular rhythm, no murmur",
        "Irregular rhythm",
        "Murmur present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "respiratory",
      "text": "Auscultate the lungs.",
      "choices": [
        "Clear bilaterally",
        "Focal or diffuse abnormal findings"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination when indicated.",
      "choices": [
        "Normal, guaiac negative, or deferred as not indicated",
        "Melena on rectal examination"
      ],
      "select": "one"
    }
  ]
}
