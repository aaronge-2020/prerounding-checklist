{
  "schema": "prerounding_workup_v1",
  "id": "severe-diarrhea",
  "title": "Diarrhea (severe/dehydrating)",
  "aliases": [
    "acute diarrhea",
    "dehydrating diarrhea"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "How many watery stools have you been having per day?",
      "choices": [
        "Fewer than 3 per day",
        "3 to 9 per day",
        "10 or more per day"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you noticed blood or mucus in your stool?",
      "choices": [
        "Neither",
        "Blood in stool",
        "Mucus in stool"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever along with the diarrhea?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have belly cramping or pain along with the diarrhea?",
      "choices": [
        "No abdominal pain",
        "Mild cramping",
        "Severe abdominal pain"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Have you taken any antibiotics in the past eight weeks?",
      "choices": [
        "No recent antibiotic use",
        "Recent antibiotic course"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "infectious",
      "text": "Have you traveled anywhere recently, especially outside the country?",
      "choices": [
        "No recent travel",
        "Recent travel to a diarrheal-illness-endemic area"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "infectious",
      "text": "Has anyone around you been sick with similar symptoms, or have you eaten anything that might have been undercooked or spoiled?",
      "choices": [
        "Neither",
        "Sick contacts with similar symptoms",
        "Suspect food exposure"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have inflammatory bowel disease, and does this feel like a prior flare?",
      "choices": [
        "No known inflammatory bowel disease",
        "Known inflammatory bowel disease, resembles a prior flare",
        "Known inflammatory bowel disease, feels different from prior flares"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Are you on chemotherapy, a transplant medication, or long-term steroids?",
      "choices": [
        "No chronic immunosuppression",
        "Chronic immunosuppression"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you noticed a change in how much you're urinating?",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt lightheaded or dizzy, especially when standing up?",
      "choices": [
        "No lightheadedness",
        "Lightheaded or dizzy on standing"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Are your stools waking you up at night?",
      "choices": [
        "No nocturnal stools",
        "Nocturnal stools"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you lost weight without trying over the past several weeks?",
      "choices": [
        "No unintentional weight loss",
        "Unintentional weight loss"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "medication",
      "text": "Do you take metformin or a laxative regularly?",
      "choices": [
        "Neither",
        "Metformin use",
        "Regular laxative use"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "general",
      "text": "Assess hydration status and orthostatic vital signs when safe.",
      "choices": [
        "Euvolemic, no orthostatic change",
        "Dry mucous membranes or poor turgor",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess hemodynamic stability.",
      "choices": [
        "Normotensive, stable",
        "Tachycardic",
        "Hypotensive or in shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for tenderness, guarding, and rebound.",
      "choices": [
        "Soft, nontender",
        "Focal tenderness without guarding",
        "Guarding, rebound, or rigidity"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for abdominal distention.",
      "choices": [
        "No distention",
        "Distention present"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Confused or lethargic"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination when indicated.",
      "choices": [
        "Normal, guaiac negative, or deferred as not indicated",
        "Gross blood on examination"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for a new rash or joint swelling suggesting a systemic inflammatory cause.",
      "choices": [
        "Neither",
        "New rash",
        "Joint swelling"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the perianal skin for irritation or breakdown from frequent stooling.",
      "choices": [
        "Skin intact",
        "Perianal irritation or breakdown"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess urine output.",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "general",
      "text": "Assess body habitus and nutritional status.",
      "choices": [
        "Normal body habitus",
        "Cachectic appearance"
      ],
      "select": "one"
    }
  ]
}
