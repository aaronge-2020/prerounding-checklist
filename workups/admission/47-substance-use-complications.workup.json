{
  "schema": "prerounding_workup_v1",
  "id": "substance-use-complications",
  "title": "Substance use disorder complications",
  "aliases": [
    "substance use",
    "intoxication",
    "withdrawal"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "medication",
      "text": "What substance did you last use, how much, and when?",
      "choices": [
        "No recent substance use",
        "Used within the past few hours",
        "Used more than a day ago"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "Do you inject the substance, and if so, where?",
      "choices": [
        "No injection use",
        "Injection use, peripheral sites only",
        "Injection use, including groin or neck sites"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "medication",
      "text": "When did you last drink alcohol, and how much do you typically drink per day?",
      "choices": [
        "No regular alcohol use",
        "Regular use, still drinking",
        "Regular heavy use, stopped in the past few days"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you ever had a seizure or seen things that weren't there when stopping alcohol before?",
      "choices": [
        "No prior withdrawal seizures or hallucinations",
        "Prior withdrawal seizure",
        "Prior withdrawal hallucinations or delirium tremens"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Are you having tremors, sweating, nausea, or anxiety since your last use?",
      "choices": [
        "None of these",
        "Mild tremor or anxiety",
        "Significant sweating, nausea, or tremor"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Are you having body aches, runny nose, yawning, or diarrhea suggesting opioid withdrawal?",
      "choices": [
        "None of these",
        "Mild opioid withdrawal symptoms",
        "Severe opioid withdrawal symptoms"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you had chest pain or a racing heart since using?",
      "choices": [
        "Neither",
        "Chest pain",
        "Racing heart or palpitations"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "respiratory",
      "text": "Has anyone had to give you naloxone or rescue breaths recently because you stopped breathing?",
      "choices": [
        "No recent overdose event",
        "Recent overdose requiring naloxone or rescue breathing"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "infectious",
      "text": "Do you have a fever, or redness and swelling at an injection site?",
      "choices": [
        "Neither",
        "Fever",
        "Redness or swelling at an injection site"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "psychiatric",
      "text": "Are you having any thoughts of hurting or killing yourself?",
      "choices": [
        "No suicidal ideation",
        "Suicidal ideation present"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you taken multiple substances together, including any pills, sedatives, or other drugs?",
      "choices": [
        "No polysubstance use",
        "Polysubstance use reported"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "psychiatric",
      "text": "Are you interested in starting treatment or medication for your substance use, like methadone, buprenorphine, or naltrexone?",
      "choices": [
        "Not currently interested",
        "Interested in starting treatment"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess level of consciousness and respiratory drive.",
      "choices": [
        "Alert with normal respiratory drive",
        "Sedated but arousable",
        "Unresponsive or inadequate respiratory drive"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "medication",
      "text": "Assess pupil size.",
      "choices": [
        "Normal pupils",
        "Pinpoint pupils",
        "Dilated pupils"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "medication",
      "text": "Assess for tremor, diaphoresis, and agitation suggesting withdrawal.",
      "choices": [
        "None present",
        "Mild tremor or diaphoresis",
        "Marked tremor, diaphoresis, or agitation"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess heart rate and blood pressure.",
      "choices": [
        "Normal vital signs",
        "Tachycardic or hypertensive",
        "Bradycardic or hypotensive"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "general",
      "text": "Assess temperature for fever.",
      "choices": [
        "Afebrile",
        "Febrile"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect injection sites and skin for track marks, abscess, or cellulitis.",
      "choices": [
        "No skin or soft tissue infection",
        "Track marks without active infection",
        "Abscess or cellulitis present"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Auscultate the heart for a new murmur suggesting endocarditis.",
      "choices": [
        "No murmur",
        "New murmur present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "psychiatric",
      "text": "Assess for hallucinations or perceptual disturbance.",
      "choices": [
        "No hallucinations",
        "Hallucinations present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for tremor progressing to seizure activity or delirium.",
      "choices": [
        "No seizure activity or delirium",
        "Active seizure or delirium tremens"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for injury or bruising suggesting a fall or assault while intoxicated.",
      "choices": [
        "No injury",
        "Injury present"
      ],
      "select": "one"
    }
  ]
}
