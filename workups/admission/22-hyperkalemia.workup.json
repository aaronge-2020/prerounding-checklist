{
  "schema": "prerounding_workup_v1",
  "id": "hyperkalemia",
  "title": "Electrolyte abnormality – hyperkalemia",
  "aliases": [
    "high potassium"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "genitourinary",
      "text": "Do you have kidney disease, and if you're on dialysis, have you missed a session?",
      "choices": [
        "Neither",
        "Known chronic kidney disease, no missed dialysis",
        "Known dialysis dependence with a missed session"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "Do you take a blood pressure medication ending in -pril or -sartan, or a potassium-sparing water pill like spironolactone?",
      "choices": [
        "Neither",
        "ACE inhibitor or ARB use",
        "Potassium-sparing diuretic use"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "medication",
      "text": "Have you taken any ibuprofen or other NSAIDs recently?",
      "choices": [
        "No NSAID use",
        "NSAID use"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "medication",
      "text": "Have you taken the antibiotic trimethoprim-sulfamethoxazole (Bactrim) recently?",
      "choices": [
        "No recent trimethoprim-sulfamethoxazole use",
        "Recent trimethoprim-sulfamethoxazole use"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Do you take a potassium supplement, or use a salt substitute?",
      "choices": [
        "Neither",
        "Potassium supplement use",
        "Salt substitute use"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had significant muscle pain, or has your urine looked dark like tea or cola?",
      "choices": [
        "Neither",
        "Muscle pain",
        "Dark, tea-colored urine"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with cancer, or started chemotherapy recently?",
      "choices": [
        "Neither",
        "Known malignancy",
        "Recently started chemotherapy"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt weak or noticed numbness or tingling?",
      "choices": [
        "Neither",
        "Mild weakness or paresthesias",
        "Severe weakness or paralysis"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you felt your heart racing, or did you pass out?",
      "choices": [
        "Neither",
        "Palpitations",
        "Syncope or near-syncope"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you lost weight without trying, or noticed new darkening of your skin?",
      "choices": [
        "No adrenal insufficiency symptoms",
        "Fatigue and unintentional weight loss",
        "New skin darkening"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes, and have you noticed excessive thirst, urination, or a fruity breath smell?",
      "choices": [
        "No known diabetes",
        "Known diabetes with polyuria or polydipsia",
        "Known diabetes with symptoms of diabetic ketoacidosis"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you received a large blood transfusion recently?",
      "choices": [
        "No recent transfusion",
        "Recent large-volume blood transfusion"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Were you crushed under something heavy, or stuck in one position for a long time?",
      "choices": [
        "Neither",
        "Crush injury",
        "Prolonged immobilization or extended down time"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess cardiac rhythm.",
      "choices": [
        "Regular rate and rhythm",
        "Bradycardic",
        "Irregular rhythm"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess muscle strength.",
      "choices": [
        "Normal strength",
        "Mild weakness",
        "Severe weakness or flaccid paralysis"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess deep tendon reflexes.",
      "choices": [
        "Normal reflexes",
        "Diminished or absent reflexes"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "general",
      "text": "Assess overall volume status.",
      "choices": [
        "Euvolemic",
        "Hypervolemic, with edema",
        "Hypovolemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Palpate muscle groups for focal tenderness or swelling suggesting rhabdomyolysis.",
      "choices": [
        "No focal muscle tenderness or swelling",
        "Focal muscle tenderness or swelling"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Inspect the dialysis access site, if present.",
      "choices": [
        "No dialysis access or site normal and functioning",
        "Dialysis access with concern for thrombosis or infection"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for hyperpigmentation.",
      "choices": [
        "Normal skin color",
        "Skin hyperpigmentation"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert",
        "Confused or lethargic"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess urine output.",
      "choices": [
        "Normal urine output",
        "Decreased or absent urine output"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Palpate peripheral pulses for regularity and quality.",
      "choices": [
        "Regular, normal pulses",
        "Irregular or weak pulses"
      ],
      "select": "one"
    }
  ]
}
