  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have cirrhosis or liver disease, and do you know what caused it, like alcohol or hepatitis?",
      "choices": [
        "No known liver disease",
        "Known cirrhosis from alcohol",
        "Known cirrhosis from viral hepatitis or another cause"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Has your belly gotten more swollen or your pants tighter recently?",
      "choices": [
        "No increased abdominal girth",
        "Increased abdominal girth or new ascites"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
