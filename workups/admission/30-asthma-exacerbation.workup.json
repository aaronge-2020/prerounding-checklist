{
  "schema": "prerounding_workup_v1",
  "id": "asthma-exacerbation",
  "title": "Asthma exacerbation",
  "aliases": [
    "asthma attack",
    "reactive airway"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "respiratory",
      "text": "Did anything seem to trigger this — an allergen, a cold, or exercise?",
      "choices": [
        "No clear trigger identified",
        "Known allergen exposure",
        "Viral upper respiratory infection",
        "Exercise-induced"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "Do you have a known sensitivity to aspirin or NSAIDs like ibuprofen?",
      "choices": [
        "No known sensitivity",
        "Known NSAID or aspirin sensitivity"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "respiratory",
      "text": "Do you take a daily controller inhaler for your asthma, and has it been keeping you well controlled?",
      "choices": [
        "Well-controlled on a controller medication",
        "Poorly controlled, frequent rescue inhaler use",
        "No controller medication prescribed"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "respiratory",
      "text": "Have you ever been hospitalized or put on a breathing machine for an asthma attack before?",
      "choices": [
        "No prior severe exacerbation",
        "Prior hospitalization without ICU admission",
        "Prior ICU admission or intubation"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "How often have you been using your rescue inhaler?",
      "choices": [
        "Fewer than twice a week",
        "Daily use",
        "Using the rescue inhaler more than every few hours currently"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "respiratory",
      "text": "Are you able to speak in full sentences right now, or do you have to stop and catch your breath?",
      "choices": [
        "Able to speak in full sentences",
        "Speaks in phrases",
        "Speaks in single words or unable to speak"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "respiratory",
      "text": "Have you been waking up at night because of your asthma?",
      "choices": [
        "No nighttime awakening",
        "Occasional nighttime awakening",
        "Frequent nighttime awakening"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "respiratory",
      "text": "Do you feel tightness in your chest?",
      "choices": [
        "No chest tightness",
        "Chest tightness"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Do you smoke, or are you regularly around someone else's smoke?",
      "choices": [
        "No smoke exposure",
        "Active smoking or secondhand smoke exposure"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "medication",
      "text": "Have you taken a course of oral steroids for your asthma recently?",
      "choices": [
        "No recent oral steroid course",
        "Recent oral steroid course"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "skin",
      "text": "Did you break out in hives or notice facial swelling along with this episode?",
      "choices": [
        "Neither",
        "Hives",
        "Facial swelling"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "ent",
      "text": "Does it feel like your throat is tight, or has your voice changed?",
      "choices": [
        "Neither",
        "Throat tightness",
        "Voice change"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess work of breathing and ability to speak in full sentences.",
      "choices": [
        "Normal work of breathing, speaks in full sentences",
        "Accessory muscle use",
        "Unable to speak in full sentences"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "respiratory",
      "text": "Auscultate for wheeze and air movement.",
      "choices": [
        "Normal air entry, no wheeze",
        "Wheeze with adequate air movement",
        "Minimal air movement, silent chest"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess oxygen saturation.",
      "choices": [
        "Normal saturation",
        "Mildly hypoxemic",
        "Severely hypoxemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess for pulsus paradoxus.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status for fatigue or drowsiness.",
      "choices": [
        "Alert",
        "Drowsy or fatigued"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess breath sounds for asymmetry suggesting pneumothorax.",
      "choices": [
        "Symmetric breath sounds",
        "Unilateral decreased breath sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for hives or angioedema.",
      "choices": [
        "None",
        "Hives or angioedema present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "ent",
      "text": "Assess for stridor.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess for an S3 gallop or elevated jugular venous pressure suggesting a cardiac contributor.",
      "choices": [
        "Neither",
        "S3 gallop or elevated jugular venous pressure"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "skin",
      "text": "Assess for cyanosis.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    }
  ]
}
