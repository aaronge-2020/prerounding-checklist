{
  "schema": "prerounding_workup_v1",
  "id": "stroke-tia",
  "title": "Stroke (CVA) or TIA",
  "aliases": [
    "cerebrovascular accident",
    "transient ischemic attack"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "neurologic",
      "text": "What time were you last seen acting and looking completely normal?",
      "choices": [
        "Within the past 4.5 hours",
        "Between 4.5 and 24 hours ago",
        "More than 24 hours ago or unknown"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "neurologic",
      "text": "Did your symptoms hit you all at once at their worst, get worse in sudden steps, or build up gradually over hours?",
      "choices": [
        "Sudden onset, maximal deficit immediately",
        "Stepwise progression",
        "Gradual progression over hours"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Are your symptoms still going on, or did they completely go away, and if so how quickly?",
      "choices": [
        "Symptoms persistent",
        "Resolved completely within an hour",
        "Resolved within 24 hours"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Do you have a headache along with this, and if so, is it the worst headache of your life?",
      "choices": [
        "No headache",
        "Mild headache",
        "Severe, worst-of-life headache"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "neurologic",
      "text": "Did anyone see you shake or convulse when this started?",
      "choices": [
        "No witnessed seizure activity",
        "Witnessed seizure activity"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Are you currently taking a blood thinner?",
      "choices": [
        "Not anticoagulated",
        "Currently anticoagulated"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you hit your head recently?",
      "choices": [
        "No recent head trauma",
        "Recent head trauma"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Have you been diagnosed with atrial fibrillation?",
      "choices": [
        "No known atrial fibrillation",
        "Known atrial fibrillation"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes, and could your blood sugar have dropped low before this started?",
      "choices": [
        "No known diabetes",
        "Known diabetes with possible hypoglycemia symptoms"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "neurologic",
      "text": "Do you get migraines with visual or sensory auras, and does this feel like one of those?",
      "choices": [
        "No history of migraine with aura",
        "Known migraine with aura, resembles prior episodes"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had trouble finding the right words, or has your speech sounded slurred?",
      "choices": [
        "No speech change",
        "Difficulty finding words",
        "Slurred speech"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "eyes",
      "text": "Have you had any change in your vision, like losing sight in one eye, a blind spot, or double vision?",
      "choices": [
        "No vision change",
        "Monocular vision loss",
        "Visual field cut or double vision"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you felt dizzy, off-balance, or clumsy with your arms or legs?",
      "choices": [
        "None of these",
        "Vertigo or imbalance",
        "Limb incoordination"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Has your blood pressure been well controlled, and have you been told you have narrowing in your neck arteries?",
      "choices": [
        "Well-controlled hypertension, no known carotid disease",
        "Poorly controlled hypertension",
        "Known carotid artery disease"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for facial droop.",
      "choices": [
        "Symmetric facial movement",
        "Unilateral facial droop"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for arm drift or weakness.",
      "choices": [
        "No drift or weakness",
        "Unilateral arm drift or weakness"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for leg weakness.",
      "choices": [
        "No leg weakness",
        "Unilateral leg weakness"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess speech and language.",
      "choices": [
        "Normal speech and language",
        "Dysarthria",
        "Aphasia"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "eyes",
      "text": "Assess visual fields.",
      "choices": [
        "Full visual fields",
        "Visual field cut"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for gaze deviation.",
      "choices": [
        "Midline gaze",
        "Forced gaze deviation"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess sensation for a unilateral deficit.",
      "choices": [
        "Normal sensation",
        "Unilateral sensory loss"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess coordination with finger-to-nose and heel-to-shin testing.",
      "choices": [
        "Normal coordination",
        "Dysmetria or ataxia"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess level of consciousness.",
      "choices": [
        "Alert",
        "Drowsy",
        "Unresponsive"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Measure blood pressure.",
      "choices": [
        "Normotensive",
        "Hypertensive, requiring management before thrombolysis consideration"
      ],
      "select": "one"
    },
    {
      "id": "exam-11",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess cardiac rhythm.",
      "choices": [
        "Regular rhythm",
        "Irregular rhythm"
      ],
      "select": "one"
    },
    {
      "id": "exam-12",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess pupil size and symmetry for a herniation syndrome.",
      "choices": [
        "Normal, reactive, and symmetric",
        "Asymmetric or a fixed, dilated pupil"
      ],
      "select": "one"
    }
  ]
}
