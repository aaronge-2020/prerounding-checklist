{
  "schema": "prerounding_workup_v1",
  "id": "hyponatremia",
  "title": "Electrolyte abnormality – hyponatremia",
  "aliases": [
    "low sodium",
    "SIADH"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "general",
      "text": "Have you felt unusually thirsty or dizzy, or noticed swelling or shortness of breath?",
      "choices": [
        "No symptoms of volume depletion or overload",
        "Thirst or dizziness suggesting hypovolemia",
        "Edema or dyspnea suggesting volume overload"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "Are you taking a water pill, and if so, do you know which kind?",
      "choices": [
        "No diuretic use",
        "Thiazide diuretic use",
        "Loop diuretic use"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had vomiting or diarrhea recently?",
      "choices": [
        "Neither",
        "Vomiting",
        "Diarrhea"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been drinking an unusually large amount of water or other fluids?",
      "choices": [
        "No excessive fluid intake",
        "Excessive water or fluid intake"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Are you taking an antidepressant or a seizure medication like carbamazepine?",
      "choices": [
        "No SIADH-associated medication",
        "Currently taking an SIADH-associated medication"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with cancer, particularly lung cancer?",
      "choices": [
        "No known malignancy",
        "Known malignancy other than lung cancer",
        "Known lung cancer"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you lost weight without trying, or noticed new darkening of your skin?",
      "choices": [
        "No adrenal insufficiency symptoms",
        "Fatigue and unintentional weight loss",
        "New skin darkening"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you felt unusually cold, gained weight, or become more constipated than usual?",
      "choices": [
        "No hypothyroid symptoms",
        "Cold intolerance",
        "Weight gain or constipation"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you have heart failure, cirrhosis, or a kidney condition called nephrotic syndrome?",
      "choices": [
        "None of these",
        "Known heart failure",
        "Known cirrhosis or nephrotic syndrome"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had a headache, nausea, or confusion along with this?",
      "choices": [
        "None of these",
        "Headache or nausea",
        "Confusion or lethargy"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "neurologic",
      "text": "Did anyone witness you having a seizure?",
      "choices": [
        "No witnessed seizure",
        "Witnessed seizure"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "general",
      "text": "Have these symptoms been building gradually over weeks, or did they come on suddenly within the past two days?",
      "choices": [
        "Chronic, gradual onset over weeks",
        "Acute onset within 48 hours"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Did you do an endurance exercise, like a marathon, while drinking a lot of water?",
      "choices": [
        "No recent endurance exercise with excess water intake",
        "Recent endurance exercise with excess water intake"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "general",
      "text": "Assess overall volume status.",
      "choices": [
        "Euvolemic",
        "Hypovolemic, with dry mucous membranes or orthostatic change",
        "Hypervolemic, with edema, elevated jugular venous pressure, or ascites"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert",
        "Lethargic or confused",
        "Obtunded"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "skin",
      "text": "Assess skin turgor.",
      "choices": [
        "Normal skin turgor",
        "Poor skin turgor"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess jugular venous pressure.",
      "choices": [
        "Normal jugular venous pressure",
        "Elevated jugular venous pressure"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Inspect and palpate the lower extremities for edema.",
      "choices": [
        "No peripheral edema",
        "Peripheral edema present"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess the abdomen for ascites.",
      "choices": [
        "No ascites",
        "Ascites present"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "endocrine",
      "text": "Assess the thyroid and deep tendon reflexes.",
      "choices": [
        "Normal thyroid exam and reflexes",
        "Goiter or delayed reflex relaxation"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for hyperpigmentation.",
      "choices": [
        "Normal skin color",
        "Skin hyperpigmentation"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess deep tendon reflexes.",
      "choices": [
        "Normal reflexes",
        "Diminished reflexes"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for active or recent seizure activity.",
      "choices": [
        "None observed",
        "Active or recent seizure activity"
      ],
      "select": "one"
    }
  ]
}
