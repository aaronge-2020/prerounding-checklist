{
  "schema": "prerounding_workup_v1",
  "id": "cellulitis-ssti",
  "title": "Cellulitis / skin and soft tissue infection",
  "aliases": [
    "cellulitis",
    "skin infection",
    "abscess"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "skin",
      "text": "Has the redness spread slowly over days, or rapidly over just a few hours?",
      "choices": [
        "Gradual spread over days",
        "Rapid spread over hours"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "skin",
      "text": "Does the pain feel proportionate to how the area looks, or is it much more painful than it looks?",
      "choices": [
        "Pain proportionate to the redness",
        "Pain out of proportion to the visible findings"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever with shaking chills?",
      "choices": [
        "No fever",
        "Subjective fever",
        "Fever with rigors"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "skin",
      "text": "Is any pus or fluid draining from the area?",
      "choices": [
        "No purulent drainage",
        "Purulent drainage present"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "skin",
      "text": "Did you have a cut, wound, bite, or injection at that spot before this started?",
      "choices": [
        "No known preceding skin break",
        "Known wound, bite, or injection site",
        "Recent skin trauma"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes, and if so, do you have numbness or reduced feeling in your feet?",
      "choices": [
        "No known diabetes",
        "Known diabetes without neuropathy",
        "Known diabetes with peripheral neuropathy"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "medication",
      "text": "Are you on chemotherapy, a transplant medication, or long-term steroids?",
      "choices": [
        "No chronic immunosuppression",
        "Chronic immunosuppression"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "medication",
      "text": "Do you currently inject drugs?",
      "choices": [
        "No active intravenous drug use",
        "Active intravenous drug use"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "skin",
      "text": "Have you had infections in this same spot before, or do you have chronic swelling in that limb?",
      "choices": [
        "First episode at this site",
        "Recurrent episodes at the same site",
        "Known chronic lymphedema"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Is the leg swollen without any redness or warmth?",
      "choices": [
        "Erythema and warmth present, typical of cellulitis",
        "Isolated swelling without erythema or warmth"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "infectious",
      "text": "Have you or your family noticed any new confusion along with this infection?",
      "choices": [
        "No confusion or altered mental status",
        "Confusion or altered mental status"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "infectious",
      "text": "Was the wound exposed to salt water, fresh water, or soil?",
      "choices": [
        "No relevant water or soil exposure",
        "Salt water or fresh water exposure",
        "Soil exposure"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "infectious",
      "text": "Were you bitten by an animal or insect before this started?",
      "choices": [
        "Neither",
        "Animal bite",
        "Insect bite"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the borders of the erythema.",
      "choices": [
        "Well-demarcated borders",
        "Poorly demarcated, spreading borders"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for bullae, crepitus, or skin necrosis.",
      "choices": [
        "None of these",
        "Bullae present",
        "Crepitus or skin necrosis"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "skin",
      "text": "Palpate for fluctuance suggesting an underlying abscess.",
      "choices": [
        "No fluctuance",
        "Fluctuant mass"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for lymphangitic streaking.",
      "choices": [
        "No streaking",
        "Lymphangitic streaking present"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "hematologic",
      "text": "Palpate for tender regional lymphadenopathy.",
      "choices": [
        "No regional lymphadenopathy",
        "Tender regional lymphadenopathy"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "skin",
      "text": "Assess whether the pain on exam is proportionate to the visible findings.",
      "choices": [
        "Pain proportionate to exam findings",
        "Pain out of proportion to exam findings"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess sensation over the affected area.",
      "choices": [
        "Normal sensation",
        "Decreased sensation or anesthesia over the area"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "general",
      "text": "Assess general appearance and vital signs.",
      "choices": [
        "Well-appearing, normal vital signs",
        "Toxic-appearing, tachycardic",
        "Hypotensive or septic-appearing"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess distal pulses and perfusion of the affected limb.",
      "choices": [
        "Normal distal pulses and perfusion",
        "Diminished pulses or poor perfusion"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess any adjacent joint for involvement.",
      "choices": [
        "No adjacent joint involvement",
        "Adjacent joint swelling or restricted motion"
      ],
      "select": "one"
    }
  ]
}
