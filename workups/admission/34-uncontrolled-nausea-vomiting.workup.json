  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you vomited anything that looked like blood or coffee grounds, or bile that was bright green or yellow?",
      "choices": [
        "Neither",
        "Coffee-ground or bloody emesis",
        "Bilious emesis"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Are you able to keep any liquids down?",
      "choices": [
        "Tolerating oral fluids",
        "Unable to tolerate oral fluids"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have belly pain along with the nausea?",
