{
  "schema": "prerounding_workup_v1",
  "id": "severe-new-headache",
  "title": "Headache (severe or new-onset)",
  "aliases": [
    "worst headache of life",
    "thunderclap headache"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "neurologic",
      "text": "Did the headache build up gradually over hours, or hit you at full intensity within a minute?",
      "choices": [
        "Gradual onset over hours",
        "Thunderclap onset, maximal intensity within a minute"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "neurologic",
      "text": "Does this headache feel like the ones you usually get, or is this the worst headache of your life?",
      "choices": [
        "Similar to prior headaches",
        "First-ever severe headache or worst of life"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "infectious",
      "text": "Do you have a fever along with the headache?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Is your neck stiff along with the headache?",
      "choices": [
        "No neck stiffness",
        "Neck stiffness"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "eyes",
      "text": "Has your vision changed or blurred along with the headache?",
      "choices": [
        "No vision change",
        "Blurred vision",
        "Vision loss"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had any weakness, numbness, or trouble speaking along with the headache?",
      "choices": [
        "None of these",
        "Weakness or numbness",
        "Speech change"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Does your jaw hurt when you chew, or is your scalp tender to touch?",
      "choices": [
        "Neither",
        "Jaw claudication",
        "Scalp tenderness"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "general",
      "text": "How old are you?",
      "choices": [
        "Under 50 years old",
        "50 years or older"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "neurologic",
      "text": "Does the headache get worse when you strain, cough, or bear down, or when you lie flat?",
      "choices": [
        "No positional or straining component",
        "Worse with straining, coughing, or bearing down",
        "Worse lying flat, improved standing"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Do you have neck pain, or did you have a recent neck injury or chiropractic adjustment?",
      "choices": [
        "Neither",
        "Neck pain",
        "Recent neck trauma or chiropractic manipulation"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "reproductive",
      "text": "Are you currently pregnant or recently gave birth, and has your blood pressure been high?",
      "choices": [
        "Not pregnant or postpartum",
        "Pregnant or postpartum with elevated blood pressure"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with cancer, or are you on medications that suppress your immune system?",
      "choices": [
        "Neither",
        "Known malignancy",
        "Known immunosuppression"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "medication",
      "text": "Are you on a blood thinner?",
      "choices": [
        "No anticoagulant use",
        "Anticoagulant use"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you hit your head recently?",
      "choices": [
        "No recent head trauma",
        "Recent head trauma"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Confused or altered"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for nuchal rigidity.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit.",
      "choices": [
        "No focal deficit",
        "Focal deficit present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess pupil size and symmetry.",
      "choices": [
        "Normal, reactive, and symmetric",
        "Asymmetric or a fixed, dilated pupil"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "eyes",
      "text": "Assess for papilledema on fundoscopic exam.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Palpate the temporal arteries.",
      "choices": [
        "Nontender",
        "Tender or thickened temporal artery"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Measure blood pressure.",
      "choices": [
        "Normotensive",
        "Severely hypertensive"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess neck range of motion and tenderness.",
      "choices": [
        "Normal range of motion, nontender",
        "Decreased range of motion or tenderness"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "eyes",
      "text": "Assess visual fields and acuity.",
      "choices": [
        "Normal fields and acuity",
        "Visual field cut or reduced acuity"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for a petechial or purpuric rash.",
      "choices": [
        "No rash",
        "Petechial or purpuric rash"
      ],
      "select": "one"
    }
  ]
}
