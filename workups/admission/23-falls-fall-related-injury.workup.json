{
  "schema": "prerounding_workup_v1",
  "id": "falls-fall-related-injury",
  "title": "Falls / fall-related injury",
  "aliases": [
    "fall",
    "mechanical fall"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "functional",
      "text": "Did you trip or slip, or do you not remember what happened before you fell?",
      "choices": [
        "Witnessed mechanical fall, tripped or slipped",
        "Unwitnessed fall",
        "Witnessed loss of consciousness before falling"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "neurologic",
      "text": "Did you feel lightheaded, or have chest pain or a racing heart right before you fell?",
      "choices": [
        "No prodrome, tripped or slipped",
        "Presyncope or lightheadedness before falling",
        "Chest pain or palpitations before falling"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Did you black out or lose consciousness during the fall?",
      "choices": [
        "No loss of consciousness",
        "Brief loss of consciousness",
        "Prolonged loss of consciousness"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Did you hit your head when you fell?",
      "choices": [
        "No head strike",
        "Head strike without loss of consciousness",
        "Head strike with loss of consciousness"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Are you on a blood thinner?",
      "choices": [
        "No anticoagulant use",
        "Anticoagulant use"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "functional",
      "text": "How many times have you fallen in the past year?",
      "choices": [
        "First fall in the past year",
        "Two or more falls in the past year"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "medication",
      "text": "Do you take any sleep or sedative medications?",
      "choices": [
        "No sedative or hypnotic use",
        "Sedative or hypnotic use"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "medication",
      "text": "Has your blood pressure medication been started or increased recently?",
      "choices": [
        "No recent antihypertensive change",
        "New or increased antihypertensive dose"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "How long were you on the ground before you were able to get up or someone found you?",
      "choices": [
        "Under one hour",
        "Several hours",
        "Unable to get up until found after a prolonged period"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "eyes",
      "text": "Do you have any known vision problems?",
      "choices": [
        "No known vision impairment",
        "Known vision impairment"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Are you able to put weight on the leg or arm that's hurting?",
      "choices": [
        "No pain preventing weight-bearing",
        "Hip or extremity pain",
        "Unable to bear weight at all"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "medication",
      "text": "Did you drink alcohol before you fell?",
      "choices": [
        "No alcohol use prior to the fall",
        "Alcohol use prior to the fall"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "functional",
      "text": "Was there anything at home that might have contributed, like poor lighting or clutter on the floor?",
      "choices": [
        "No environmental hazard identified",
        "Environmental hazard identified, such as poor lighting or clutter"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "neurologic",
      "text": "Did you feel the room spinning right before you fell?",
      "choices": [
        "No vertigo or spinning sensation",
        "Vertigo or spinning sensation preceding the fall"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the scalp for hematoma or laceration.",
      "choices": [
        "No scalp hematoma or laceration",
        "Scalp hematoma or laceration present"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit.",
      "choices": [
        "No focal deficit",
        "Focal deficit present"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Altered mental status"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess orthostatic vital signs when safe.",
      "choices": [
        "Negative orthostatics",
        "Positive orthostatic hypotension"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess cardiac rhythm.",
      "choices": [
        "Regular rhythm",
        "Irregular rhythm"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess the hip and pelvis for a suspected fracture.",
      "choices": [
        "Normal, able to bear weight",
        "Pain with a shortened, externally rotated leg suggesting fracture"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Inspect extremities for deformity or swelling.",
      "choices": [
        "No deformity or swelling",
        "Deformity or swelling present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect for pressure injury or skin breakdown from prolonged time on the ground.",
      "choices": [
        "No pressure injury or skin breakdown",
        "Pressure injury or skin breakdown present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess gait and balance when safe.",
      "choices": [
        "Normal gait and balance",
        "Unsteady gait",
        "Unable to ambulate safely"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "eyes",
      "text": "Assess visual acuity.",
      "choices": [
        "Normal visual acuity",
        "Impaired visual acuity"
      ],
      "select": "one"
    }
  ]
}
