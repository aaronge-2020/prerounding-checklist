{
  "schema": "prerounding_workup_v1",
  "id": "altered-mental-status-delirium",
  "title": "Altered mental status / delirium",
  "aliases": [
    "confusion",
    "delirium"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "neurologic",
      "text": "Has the confusion been a stable long-standing pattern, did it come on suddenly over hours, or does it come and go throughout the day?",
      "choices": [
        "Chronic, stable baseline confusion",
        "Acute onset over hours",
        "Fluctuating course over the day"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "neurologic",
      "text": "Before the confusion started, did you or your family notice any weakness on one side, facial drooping, or trouble speaking?",
      "choices": [
        "None",
        "Unilateral weakness or facial droop",
        "Speech change"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had a recent fall or hit your head?",
      "choices": [
        "No recent fall or head trauma",
        "Recent fall or head trauma"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "infectious",
      "text": "Did you have a fever before the confusion started?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Have you started any new sleep, anxiety, allergy, or pain medications recently?",
      "choices": [
        "No new sedating medication",
        "New sedative or anticholinergic medication",
        "New or increased opioid dose"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Do you drink alcohol regularly, and when was your last drink?",
      "choices": [
        "No regular alcohol use",
        "Regular alcohol use, last drink more than 48 hours ago",
        "Regular alcohol use, last drink within 48 hours"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes, and has your insulin or diabetes pill dose changed recently?",
      "choices": [
        "No known diabetes",
        "Known diabetes without recent medication change",
        "Known diabetes with a recent insulin or sulfonylurea dose change"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have cirrhosis or liver disease, and have you been constipated, had a stomach bleed, or felt sick recently?",
      "choices": [
        "No known cirrhosis",
        "Known cirrhosis without a clear trigger",
        "Known cirrhosis with recent constipation, gastrointestinal bleeding, or infection"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "genitourinary",
      "text": "Do you have kidney disease, and if you're on dialysis, have you missed a session?",
      "choices": [
        "No known chronic kidney disease",
        "Known chronic kidney disease, no missed dialysis",
        "Known dialysis dependence with a missed session"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "genitourinary",
      "text": "Do you have a history of being unable to empty your bladder?",
      "choices": [
        "No known urinary retention",
        "Known urinary retention"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you been severely constipated or had trouble having a bowel movement recently?",
      "choices": [
        "No known severe constipation",
        "Known severe constipation or fecal impaction"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "general",
      "text": "Are you in significant pain that hasn't been controlled?",
      "choices": [
        "No uncontrolled pain",
        "Uncontrolled pain"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "neurologic",
      "text": "Did anyone witness you having a seizure before the confusion started?",
      "choices": [
        "No witnessed seizure",
        "Witnessed seizure activity"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "neurologic",
      "text": "Before this episode, did you or your family notice any memory or thinking problems as your normal baseline?",
      "choices": [
        "No known baseline cognitive impairment",
        "Known mild baseline dementia",
        "Known moderate to severe baseline dementia"
      ],
      "select": "one"
    },
    {
      "id": "history-15",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been eating poorly or drinking heavily for an extended period?",
      "choices": [
        "No poor nutrition or alcohol use disorder",
        "Poor nutrition or alcohol use disorder"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess the level of arousal.",
      "choices": [
        "Alert",
        "Hypoactive or lethargic",
        "Hyperactive or agitated"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess attention.",
      "choices": [
        "Normal attention",
        "Inattentive"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for focal motor weakness or facial asymmetry.",
      "choices": [
        "Symmetric, no focal weakness",
        "Focal weakness or facial asymmetry"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess pupil size and reactivity.",
      "choices": [
        "Normal, reactive pupils",
        "Pinpoint pupils",
        "Dilated or sluggish pupils"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "endocrine",
      "text": "Check fingerstick glucose.",
      "choices": [
        "Normal glucose",
        "Hypoglycemic",
        "Markedly hyperglycemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "general",
      "text": "Assess vital signs for fever or hemodynamic instability.",
      "choices": [
        "Normal vital signs",
        "Febrile or tachycardic",
        "Hypotensive"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for asterixis.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for nuchal rigidity.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess for a distended, palpable bladder.",
      "choices": [
        "Nondistended",
        "Distended, palpable bladder"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Perform a rectal examination for fecal impaction when indicated.",
      "choices": [
        "Normal or deferred as not indicated",
        "Fecal impaction present"
      ],
      "select": "one"
    },
    {
      "id": "exam-11",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for signs of trauma or intravenous drug use.",
      "choices": [
        "Normal skin",
        "Bruising or signs of trauma",
        "Needle track marks"
      ],
      "select": "one"
    },
    {
      "id": "exam-12",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for tremor suggesting alcohol or sedative withdrawal.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    }
  ]
}
