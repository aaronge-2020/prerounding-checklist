{
  "schema": "prerounding_workup_v1",
  "id": "psychiatric-crisis-medical-comorbidity",
  "title": "Psychiatric crisis with medical comorbidity",
  "aliases": [
    "psychiatric crisis",
    "medical clearance"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "psychiatric",
      "text": "Are you having any thoughts of hurting or killing yourself right now?",
      "choices": [
        "No suicidal ideation",
        "Passive suicidal ideation without a plan",
        "Active suicidal ideation with a plan or intent"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "psychiatric",
      "text": "Are you having any thoughts of hurting someone else?",
      "choices": [
        "No homicidal ideation",
        "Homicidal ideation present"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "psychiatric",
      "text": "Have you taken any pills, medications, or other substances in an attempt to harm yourself?",
      "choices": [
        "No ingestion",
        "Reported ingestion or overdose attempt"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "psychiatric",
      "text": "Are you hearing voices or seeing things that other people don't, and if so, are they telling you to do anything?",
      "choices": [
        "No hallucinations",
        "Hallucinations without command content",
        "Command hallucinations"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "neurologic",
      "text": "Did this confusion or behavior change come on suddenly, over hours to days, or has it been your usual pattern for a long time?",
      "choices": [
        "Chronic, longstanding baseline",
        "Sudden onset over hours to days"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Have you been drinking alcohol or using drugs recently, or stopped using something you normally use?",
      "choices": [
        "Neither",
        "Recent alcohol or drug use",
        "Recent cessation of alcohol or drug use"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "psychiatric",
      "text": "Do you have a diagnosed psychiatric condition, and have you been taking your psychiatric medications as prescribed?",
      "choices": [
        "No known psychiatric diagnosis",
        "Known psychiatric diagnosis, taking medications as prescribed",
        "Known psychiatric diagnosis, missed medications"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever or felt physically ill along with this?",
      "choices": [
        "No fever or physical illness",
        "Fever or physical illness present"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had a headache, weakness, or numbness along with this?",
      "choices": [
        "None of these",
        "Headache",
        "Weakness or numbness"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes or thyroid disease that could be affecting how you feel?",
      "choices": [
        "Neither",
        "Known diabetes",
        "Known thyroid disease"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "functional",
      "text": "Do you have somewhere safe to go, and someone who can help keep you safe if you leave here today?",
      "choices": [
        "Safe environment and support available",
        "No safe environment or support available"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "psychiatric",
      "text": "Have you been hospitalized for a psychiatric reason before, and did anything specific trigger this episode?",
      "choices": [
        "No prior psychiatric hospitalization",
        "Prior psychiatric hospitalization, similar trigger",
        "Prior psychiatric hospitalization, new or unclear trigger"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess level of consciousness, attention, and orientation.",
      "choices": [
        "Alert, attentive, and fully oriented",
        "Inattentive or fluctuating alertness",
        "Obtunded"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "general",
      "text": "Assess vital signs for fever or hemodynamic abnormality.",
      "choices": [
        "Normal vital signs",
        "Febrile",
        "Tachycardic or hypertensive"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "endocrine",
      "text": "Check fingerstick glucose.",
      "choices": [
        "Normal glucose",
        "Hypoglycemic",
        "Hyperglycemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "medication",
      "text": "Assess pupil size and reactivity for signs of intoxication or withdrawal.",
      "choices": [
        "Normal pupils",
        "Constricted pupils",
        "Dilated pupils"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "medication",
      "text": "Assess for tremor and diaphoresis suggesting withdrawal.",
      "choices": [
        "No tremor or diaphoresis",
        "Tremor or diaphoresis present"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit.",
      "choices": [
        "No focal deficit",
        "Focal deficit present"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "psychiatric",
      "text": "Assess speech, thought process, and thought content.",
      "choices": [
        "Linear, coherent thought process",
        "Disorganized speech or thought process",
        "Delusional content present"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the skin for self-harm injuries, needle marks, or evidence of trauma.",
      "choices": [
        "No injuries identified",
        "Self-harm injuries or needle marks present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Assess heart rate and rhythm.",
      "choices": [
        "Regular rate and rhythm",
        "Tachycardic",
        "Irregular rhythm"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess gait and coordination when safe.",
      "choices": [
        "Normal gait and coordination",
        "Ataxic or unsteady"
      ],
      "select": "one"
    }
  ]
}
