{
  "schema": "prerounding_workup_v1",
  "id": "hypertensive-urgency-emergency",
  "title": "Hypertensive urgency/emergency",
  "aliases": [
    "severe hypertension",
    "hypertensive emergency"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "neurologic",
      "text": "Do you have a headache, or has your vision changed?",
      "choices": [
        "Neither",
        "Headache",
        "Vision change"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you have chest pain, and does it feel like it's tearing through to your back?",
      "choices": [
        "No chest pain",
        "Chest pain without radiation to the back",
        "Chest pain tearing through to the back"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "respiratory",
      "text": "Are you short of breath?",
      "choices": [
        "No dyspnea",
        "Mild dyspnea with exertion",
        "Severe dyspnea at rest"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you or your family noticed any new confusion?",
      "choices": [
        "No new confusion",
        "New confusion"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had any weakness, numbness, or trouble speaking on one side?",
      "choices": [
        "None of these",
        "Focal weakness or numbness",
        "Speech change"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Have you missed doses of your blood pressure medication recently?",
      "choices": [
        "No missed doses",
        "Missed one or more doses of blood pressure medication"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "reproductive",
      "text": "Are you currently pregnant or did you recently give birth?",
      "choices": [
        "Not pregnant or postpartum",
        "Pregnant or postpartum"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "medication",
      "text": "Have you used cocaine, methamphetamine, or another stimulant recently?",
      "choices": [
        "No stimulant use",
        "Recent stimulant use"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you had episodes of pounding headaches, sweating, and a racing heart that come and go?",
      "choices": [
        "No episodic symptoms",
        "Episodic headache, diaphoresis, and palpitations"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "general",
      "text": "Are you in a lot of pain, or feeling especially anxious right now?",
      "choices": [
        "Neither",
        "Significant pain",
        "Significant anxiety"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you noticed a change in how much you're urinating?",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "eyes",
      "text": "Has your vision gotten blurry or spotty?",
      "choices": [
        "No visual change",
        "Blurred or spotty vision"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "cardiovascular",
      "text": "Do you have kidney disease, and has your blood pressure been consistently hard to control?",
      "choices": [
        "Neither",
        "Known chronic kidney disease",
        "Long-standing poorly controlled hypertension"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Measure blood pressure in both arms.",
      "choices": [
        "Concordant blood pressure in both arms",
        "Significant discrepancy between arms"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Confused or altered"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess for a focal neurologic deficit.",
      "choices": [
        "No focal deficit",
        "Focal deficit present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "eyes",
      "text": "Assess for papilledema or hemorrhages on fundoscopic exam.",
      "choices": [
        "Normal fundoscopic exam",
        "Papilledema or retinal hemorrhages"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "respiratory",
      "text": "Auscultate the lungs for crackles.",
      "choices": [
        "Clear bilaterally",
        "Bibasilar crackles",
        "Diffuse crackles consistent with pulmonary edema"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Auscultate heart sounds for a gallop or new murmur.",
      "choices": [
        "Normal heart sounds",
        "S3 or S4 gallop",
        "New murmur"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Palpate peripheral pulses for symmetry to help exclude aortic dissection.",
      "choices": [
        "Symmetric pulses",
        "Asymmetric or diminished pulse"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "cardiovascular",
      "text": "Inspect and palpate the lower extremities for edema.",
      "choices": [
        "No peripheral edema",
        "Peripheral edema present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "reproductive",
      "text": "Assess for hyperreflexia or clonus when pregnancy-related hypertension is a concern.",
      "choices": [
        "Not applicable or normal reflexes",
        "Hyperreflexia or clonus present"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess urine output.",
      "choices": [
        "Normal urine output",
        "Decreased urine output"
      ],
      "select": "one"
    }
  ]
}
