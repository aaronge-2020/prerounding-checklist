{
  "schema": "prerounding_workup_v1",
  "id": "acute-pancreatitis",
  "title": "Acute pancreatitis",
  "aliases": [
    "pancreatitis"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Where is your belly pain, and does it spread through to your back?",
      "choices": [
        "Epigastric pain radiating to the back",
        "Epigastric pain without radiation",
        "Diffuse abdominal pain"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "medication",
      "text": "Did you drink heavily or binge drink before this pain started?",
      "choices": [
        "No heavy alcohol use",
        "Heavy or binge alcohol use preceding symptoms"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Do you have any prior episodes of abdominal pain that occurs specifically after you eat, or have you been told you have gallstones?",
      "choices": [
        "None known",
        "Known gallstones or biliary colic"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "endocrine",
      "text": "Have you been told you have high triglycerides?",
      "choices": [
        "No known hypertriglyceridemia",
        "Known hypertriglyceridemia"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "medication",
      "text": "Have you had a procedure recently to look at your bile ducts, called an ERCP?",
      "choices": [
        "No recent ERCP",
        "Recent ERCP procedure"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "medication",
      "text": "Have you started a new medication recently, like a weight-loss or diabetes injection, an immune-suppressing drug, or a seizure medication?",
      "choices": [
        "No new pancreatitis-associated medication",
        "New pancreatitis-associated medication started"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you been vomiting along with the pain?",
      "choices": [
        "No vomiting",
        "Vomiting"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever along with the pain?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you lost weight without trying, or been told you have a mass on your pancreas?",
      "choices": [
        "Neither",
        "Unintentional weight loss",
        "Known pancreatic mass or malignancy"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had pancreatitis before?",
      "choices": [
        "First episode",
        "Recurrent episodes"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Does anyone in your family have a history of pancreatitis?",
      "choices": [
        "No known family history",
        "Known family history of pancreatitis"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had a recent injury to your abdomen?",
      "choices": [
        "No recent abdominal trauma",
        "Recent abdominal trauma"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "endocrine",
      "text": "Do you have diabetes?",
      "choices": [
        "No known diabetes",
        "Known diabetes"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Palpate the abdomen for epigastric tenderness.",
      "choices": [
        "Nontender",
        "Epigastric tenderness",
        "Diffuse tenderness with guarding or rigidity"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Auscultate bowel sounds.",
      "choices": [
        "Normal bowel sounds",
        "Hypoactive or absent bowel sounds"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect skin and sclerae for jaundice.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the flanks and periumbilical area for Grey Turner or Cullen sign.",
      "choices": [
        "Absent",
        "Present"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "general",
      "text": "Assess hemodynamic stability.",
      "choices": [
        "Normotensive, stable",
        "Tachycardic",
        "Hypotensive or in shock"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "general",
      "text": "Assess for fever or toxic appearance.",
      "choices": [
        "Well-appearing, afebrile",
        "Febrile or toxic-appearing"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "respiratory",
      "text": "Assess oxygenation for a pulmonary complication.",
      "choices": [
        "Normal oxygenation",
        "Hypoxemic"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for abdominal distention.",
      "choices": [
        "No distention",
        "Distention present"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "gastrointestinal",
      "text": "Assess for a Murphy sign.",
      "choices": [
        "Negative",
        "Positive"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess mental status.",
      "choices": [
        "Alert and oriented",
        "Confused or altered"
      ],
      "select": "one"
    }
  ]
}
