{
  "schema": "prerounding_workup_v1",
  "id": "back-pain-red-flags",
  "title": "Back pain (with red flags/neuro deficits)",
  "aliases": [
    "back pain",
    "spinal cord compression"
  ],
  "items": [
    {
      "id": "history-01",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Did this pain start after a fall or injury, or did it come on without any trauma?",
      "choices": [
        "Gradual onset without trauma",
        "Sudden onset after a fall or injury"
      ],
      "select": "one"
    },
    {
      "id": "history-02",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Does the pain wake you up at night, or is it worse when you're lying flat?",
      "choices": [
        "No night pain or positional worsening",
        "Wakes you up at night",
        "Worse lying flat"
      ],
      "select": "one"
    },
    {
      "id": "history-03",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you had any weakness or numbness in your legs?",
      "choices": [
        "No leg weakness or numbness",
        "Leg weakness or numbness"
      ],
      "select": "one"
    },
    {
      "id": "history-04",
      "kind": "history",
      "system": "neurologic",
      "text": "Have you noticed numbness around your groin or inner thighs, like the area you'd sit on a saddle?",
      "choices": [
        "No saddle numbness",
        "Saddle numbness present"
      ],
      "select": "one"
    },
    {
      "id": "history-05",
      "kind": "history",
      "system": "genitourinary",
      "text": "Have you had any trouble controlling your bladder, or trouble starting your urine stream?",
      "choices": [
        "No bladder symptoms",
        "New urinary retention or incontinence"
      ],
      "select": "one"
    },
    {
      "id": "history-06",
      "kind": "history",
      "system": "gastrointestinal",
      "text": "Have you had any new trouble controlling your bowels?",
      "choices": [
        "No bowel symptoms",
        "New bowel incontinence"
      ],
      "select": "one"
    },
    {
      "id": "history-07",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Has your walking changed recently, like feeling unsteady or your legs giving out?",
      "choices": [
        "No gait change",
        "New gait change or leg weakness"
      ],
      "select": "one"
    },
    {
      "id": "history-08",
      "kind": "history",
      "system": "infectious",
      "text": "Have you had a fever along with the back pain?",
      "choices": [
        "No fever",
        "Fever"
      ],
      "select": "one"
    },
    {
      "id": "history-09",
      "kind": "history",
      "system": "medication",
      "text": "Do you inject drugs?",
      "choices": [
        "No intravenous drug use",
        "Active intravenous drug use"
      ],
      "select": "one"
    },
    {
      "id": "history-10",
      "kind": "history",
      "system": "hematologic",
      "text": "Have you been diagnosed with cancer?",
      "choices": [
        "No known malignancy",
        "Known malignancy"
      ],
      "select": "one"
    },
    {
      "id": "history-11",
      "kind": "history",
      "system": "general",
      "text": "Have you lost weight without trying, or had night sweats?",
      "choices": [
        "Neither",
        "Unintentional weight loss",
        "Night sweats"
      ],
      "select": "one"
    },
    {
      "id": "history-12",
      "kind": "history",
      "system": "medication",
      "text": "Have you been diagnosed with osteoporosis, or are you on long-term steroids?",
      "choices": [
        "Neither",
        "Known osteoporosis",
        "Chronic steroid use"
      ],
      "select": "one"
    },
    {
      "id": "history-13",
      "kind": "history",
      "system": "medication",
      "text": "Are you on a blood thinner?",
      "choices": [
        "No anticoagulant use",
        "Anticoagulant use"
      ],
      "select": "one"
    },
    {
      "id": "history-14",
      "kind": "history",
      "system": "musculoskeletal",
      "text": "Have you had spine surgery in the past, or been told you have spinal disease like stenosis?",
      "choices": [
        "Neither",
        "Prior spine surgery",
        "Known spinal stenosis or other vertebral disease"
      ],
      "select": "one"
    },
    {
      "id": "exam-01",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Palpate the spine for focal tenderness or a step-off.",
      "choices": [
        "No focal tenderness or step-off",
        "Focal vertebral tenderness or step-off"
      ],
      "select": "one"
    },
    {
      "id": "exam-02",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess lower extremity strength for symmetry.",
      "choices": [
        "Symmetric strength throughout",
        "Asymmetric or bilateral lower extremity weakness"
      ],
      "select": "one"
    },
    {
      "id": "exam-03",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess sensation in the lower extremities and perineal region.",
      "choices": [
        "Normal sensation",
        "Decreased sensation in the legs",
        "Saddle anesthesia"
      ],
      "select": "one"
    },
    {
      "id": "exam-04",
      "kind": "exam",
      "system": "neurologic",
      "text": "Assess deep tendon reflexes in the lower extremities.",
      "choices": [
        "Normal reflexes",
        "Diminished or absent reflexes",
        "Hyperreflexia or clonus"
      ],
      "select": "one"
    },
    {
      "id": "exam-05",
      "kind": "exam",
      "system": "genitourinary",
      "text": "Assess rectal tone and for a distended bladder when clinically indicated.",
      "choices": [
        "Normal tone, nondistended bladder, or deferred as not indicated",
        "Decreased rectal tone",
        "Distended, palpable bladder"
      ],
      "select": "one"
    },
    {
      "id": "exam-06",
      "kind": "exam",
      "system": "general",
      "text": "Assess for fever.",
      "choices": [
        "Afebrile",
        "Febrile"
      ],
      "select": "one"
    },
    {
      "id": "exam-07",
      "kind": "exam",
      "system": "skin",
      "text": "Inspect the back for a wound, needle track marks, or overlying skin infection.",
      "choices": [
        "Normal skin",
        "Skin infection or needle track marks overlying the spine"
      ],
      "select": "one"
    },
    {
      "id": "exam-08",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess straight leg raise for radicular reproduction of pain.",
      "choices": [
        "Negative",
        "Positive"
      ],
      "select": "one"
    },
    {
      "id": "exam-09",
      "kind": "exam",
      "system": "musculoskeletal",
      "text": "Assess gait when safe.",
      "choices": [
        "Normal gait",
        "Unsteady or unable to ambulate safely"
      ],
      "select": "one"
    },
    {
      "id": "exam-10",
      "kind": "exam",
      "system": "hematologic",
      "text": "Palpate for lymphadenopathy or a palpable mass suggesting malignancy.",
      "choices": [
        "None",
        "Lymphadenopathy or palpable mass present"
      ],
      "select": "one"
    }
  ]
}
